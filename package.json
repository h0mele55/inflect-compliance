{
  "name": "inflect-compliance",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "tsx scripts/validate-env.ts && next build",
    "start": "next start",
    "migrate:deploy": "prisma migrate deploy",
    "prod:local": "npm run migrate:deploy && npm run build && npm start",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:ci": "jest --runInBand --forceExit --no-coverage",
    "test:coverage": "jest --coverage --forceExit",
    "test:all": "jest && playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "count-any": "node scripts/count-any.js",
    "ci:local": "node scripts/ci-local.mjs",
    "e2e:local": "node scripts/e2e-local.mjs",
    "db:test:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "db:test:down": "docker compose -f docker-compose.test.yml down -v",
    "seed:staging": "tsx scripts/seed-staging.ts",
    "staging:up": "docker compose -f docker-compose.staging.yml up -d --build",
    "staging:down": "docker compose -f docker-compose.staging.yml down",
    "smoke:staging": "node scripts/smoke-staging.mjs",
    "prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "prod:down": "docker compose -f docker-compose.prod.yml down"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@aws-sdk/s3-request-presigner": "^3.1014.0",
    "@node-saml/node-saml": "^5.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@prisma/client": "^5.20.0",
    "@sentry/nextjs": "^10.45.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.90.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "archiver": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "ioredis": "^5.10.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.400.0",
    "next": "^14.2.0",
    "next-auth": "^5.0.0-beta.30",
    "next-intl": "^4.8.3",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.15.0",
    "pino": "^10.3.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "stripe": "^20.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/archiver": "^6.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.13.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.5",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.0",
    "prisma": "^5.20.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
