# ───────────────────────────────────────────────────────────────
# Template for deploy/.env.prod (NEVER commit the real one).
#
# Copy to deploy/.env.prod on the VM, fill every `REPLACE_ME` with
# a real value, then `docker compose up -d` from deploy/.
# Generate secrets with `openssl rand -hex 32`.
# ───────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Database ───────────────────────────────────────────────────
# Pin the literal password into both URLs (compose env_file does
# NOT interpolate). Keep the POSTGRES_PASSWORD line in deploy/.env
# for compose YAML variable substitution too.
DATABASE_URL=postgresql://postgres:REPLACE_ME_PASSWORD@pgbouncer:5432/inflect_compliance?schema=public&pgbouncer=true
DIRECT_DATABASE_URL=postgresql://postgres:REPLACE_ME_PASSWORD@postgres:5432/inflect_compliance?schema=public

# ── Cache / rate limit ─────────────────────────────────────────
REDIS_URL=redis://redis:6379
RATE_LIMIT_MODE=memory

# ── NextAuth / JWT ─────────────────────────────────────────────
NEXTAUTH_URL=https://REPLACE_ME_HOSTNAME
AUTH_URL=https://REPLACE_ME_HOSTNAME
AUTH_SECRET=REPLACE_ME_AUTH_SECRET_32_BYTES_HEX
JWT_SECRET=REPLACE_ME_JWT_SECRET_32_BYTES_HEX

# ── OAuth (placeholders — swap in real client IDs when ready) ──
GOOGLE_CLIENT_ID=pending-set-in-vm
GOOGLE_CLIENT_SECRET=pending-set-in-vm
MICROSOFT_CLIENT_ID=pending-set-in-vm
MICROSOFT_CLIENT_SECRET=pending-set-in-vm
MICROSOFT_TENANT_ID=common

# ── File storage ───────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
FILE_STORAGE_ROOT=/data/uploads
STORAGE_PROVIDER=local
FILE_MAX_SIZE_BYTES=104857600

# ── Antivirus ──────────────────────────────────────────────────
CLAMAV_HOST=clamav:3310
AV_SCAN_MODE=permissive
AV_WEBHOOK_SECRET=REPLACE_ME_AV_WEBHOOK_SECRET

# ── Data protection ────────────────────────────────────────────
DATA_ENCRYPTION_KEY=REPLACE_ME_DATA_ENCRYPTION_KEY_32_BYTES_HEX

# ── CORS / origins ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://REPLACE_ME_HOSTNAME
APP_URL=https://REPLACE_ME_HOSTNAME

# ── Email (console sink — no SMTP_HOST set) ────────────────────
SMTP_FROM=noreply@inflect.app

# ── AI risk ────────────────────────────────────────────────────
AI_RISK_PROVIDER=stub
AI_RISK_ENABLED=false
