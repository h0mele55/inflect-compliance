# ─── Production Environment Variables ───────────────────────
# Copy to .env.production and fill in real values.
# Generate secrets: openssl rand -base64 32
# ────────────────────────────────────────────────────────────

# ── Database (Docker Compose sets DATABASE_URL from these) ──
POSTGRES_USER=inflect
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=inflect_production

# ── App ──
APP_PORT=3000
NEXTAUTH_URL=https://your-domain.com
AUTH_URL=https://your-domain.com

# ── Secrets (min 16 chars each, generate with openssl rand -base64 32) ──
AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ── OAuth Providers ──
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# ── File Storage (set by Docker Compose, don't change) ──
UPLOAD_DIR=/data/uploads
FILE_STORAGE_ROOT=/data/uploads

# ── CORS (comma-separated origins) ──
CORS_ALLOWED_ORIGINS=https://your-domain.com

# ── Optional ──
# RATE_LIMIT_ENABLED=true
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
