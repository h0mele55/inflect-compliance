# NextAuth
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-key-here-must-be-min-16-chars"
JWT_SECRET="your-secret-key-here-must-be-min-16-chars"

# Database
DATABASE_URL="postgres://user:password@localhost:5432/inflect"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_TENANT_ID="common"

# File Storage
UPLOAD_DIR="./uploads"

# API & Security
CORS_ALLOWED_ORIGINS="http://localhost:3000,https://production-app.com"

# Rate Limiting
# RATE_LIMIT_ENABLED="1"
# RATE_LIMIT_MODE="memory" # use 'upstash' in prod
# UPSTASH_REDIS_REST_URL="https://your-upstash-url"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
