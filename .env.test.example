# ─── Test Environment (local CI) ───
# Copy to .env.test and adjust if needed.
# Used by: scripts/ci-local.mjs, npm run ci:local

# Test database (docker-compose.test.yml)
DATABASE_URL=postgresql://test:test@localhost:5434/inflect_test?schema=public
DATABASE_URL_TEST=postgresql://test:test@localhost:5434/inflect_test?schema=public

# App secrets (dummy — never use in production)
AUTH_SECRET=test-auth-secret-that-is-long-enough-32chars
JWT_SECRET=test-jwt-secret-that-is-long-enough-32chars
NEXTAUTH_SECRET=test-auth-secret-that-is-long-enough-32chars
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

# OAuth stubs (test only)
GOOGLE_CLIENT_ID=test-google-id
GOOGLE_CLIENT_SECRET=test-google-secret
MICROSOFT_CLIENT_ID=test-ms-id
MICROSOFT_CLIENT_SECRET=test-ms-secret
MICROSOFT_TENANT_ID=test-ms-tenant

# File storage
UPLOAD_DIR=./tmp/test-uploads
FILE_STORAGE_ROOT=./tmp/test-uploads
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3006

# Skip env validation in tests
SKIP_ENV_VALIDATION=1
NODE_ENV=test
