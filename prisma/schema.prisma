generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  READER
  AUDITOR
}

enum MembershipStatus {
  INVITED
  ACTIVE
  DEACTIVATED
  REMOVED
}

enum ClauseStatus {
  NOT_STARTED
  IN_PROGRESS
  READY
  NEEDS_REVIEW
}

enum AssetType {
  INFORMATION
  APPLICATION
  SYSTEM
  SERVICE
  DATA_STORE
  INFRASTRUCTURE
  VENDOR
  PROCESS
  PEOPLE_PROCESS
  OTHER
}

enum Criticality {
  LOW
  MEDIUM
  HIGH
}

enum AssetStatus {
  ACTIVE
  RETIRED
}

enum CoverageType {
  FULL
  PARTIAL
  UNKNOWN
}

enum ExposureLevel {
  LOW
  MEDIUM
  HIGH
}

enum TreatmentDecision {
  TREAT
  TRANSFER
  TOLERATE
  AVOID
}

enum ControlStatus {
  NOT_STARTED
  PLANNED
  IN_PROGRESS
  IMPLEMENTING
  IMPLEMENTED
  NEEDS_REVIEW
  NOT_APPLICABLE // @deprecated — use Control.applicability instead
}

enum Applicability {
  APPLICABLE
  NOT_APPLICABLE
}

enum ControlFrequency {
  AD_HOC
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

// ─── Control Test Enums ───

enum TestMethod {
  MANUAL
  AUTOMATED
}

enum TestPlanStatus {
  ACTIVE
  PAUSED
}

enum TestRunStatus {
  PLANNED
  RUNNING
  COMPLETED
}

enum TestResult {
  PASS
  FAIL
  INCONCLUSIVE
}

enum TestEvidenceKind {
  FILE
  EVIDENCE
  LINK
  INTEGRATION_RESULT
}

enum EvidenceSourceType {
  MANUAL
  INTEGRATION
}

enum EvidenceLinkKind {
  FILE
  LINK
  INTEGRATION_RESULT
}

enum ControlTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  BLOCKED
}

enum EvidenceType {
  FILE
  LINK
  TEXT
}

enum FileRecordStatus {
  PENDING
  STORED
  FAILED
  DELETED
}

enum EvidenceStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum RetentionPolicy {
  NONE
  FIXED_DATE
  DAYS_AFTER_UPLOAD
}

enum ReviewAction {
  SUBMITTED
  APPROVED
  REJECTED
}

enum WorkItemType {
  AUDIT_FINDING
  CONTROL_GAP
  INCIDENT
  IMPROVEMENT
  TASK
}

enum WorkItemSeverity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WorkItemPriority {
  P0
  P1
  P2
  P3
}

enum WorkItemStatus {
  OPEN
  TRIAGED
  IN_PROGRESS
  BLOCKED
  RESOLVED
  CLOSED
  CANCELED
}

enum WorkItemSource {
  MANUAL
  TEMPLATE
  POLICY_REVIEW
  AUDIT
  INTEGRATION
}

enum TaskLinkEntityType {
  CONTROL
  FRAMEWORK_REQUIREMENT
  RISK
  ASSET
  POLICY
  EVIDENCE
  FILE
  AUDIT_PACK
  VENDOR
}

enum TaskLinkRelation {
  RELATES_TO
  EVIDENCE_FOR
  BLOCKED_BY
  CAUSED_BY
  MITIGATED_BY
}

enum PolicyStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum PolicyContentType {
  MARKDOWN
  HTML
  EXTERNAL_LINK
}

enum PolicyApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ChecklistResult {
  NOT_TESTED
  PASS
  FAIL
}

enum RiskStatus {
  OPEN
  MITIGATING
  ACCEPTED
  CLOSED
}

enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingType {
  NONCONFORMITY
  OBSERVATION
  OPPORTUNITY
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  READY_FOR_VERIFICATION
  CLOSED
}

enum ReviewCadence {
  MONTHLY
  QUARTERLY
  SEMI_ANNUALLY
  ANNUALLY
}

enum NotificationType {
  EVIDENCE_DUE_SOON
  EVIDENCE_OVERDUE
  EVIDENCE_REJECTED
  EVIDENCE_APPROVED
  POLICY_APPROVAL_NEEDED
  POLICY_ACKNOWLEDGED
  FINDING_ASSIGNED
  FINDING_VERIFIED
  TASK_ASSIGNED
  GENERAL
}

enum EmailNotificationType {
  TASK_ASSIGNED
  EVIDENCE_EXPIRING
  POLICY_APPROVAL_REQUESTED
  POLICY_APPROVED
  POLICY_REJECTED
}

enum EmailOutboxStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationDelivery {
  IMMEDIATE
  DAILY_DIGEST
  DISABLED
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum SuggestionSessionStatus {
  DRAFT
  GENERATED
  APPLIED
  DISMISSED
}

enum SuggestionItemStatus {
  PENDING
  ACCEPTED
  REJECTED
  EDITED
}

enum IdentityProviderType {
  SAML
  OIDC
}

enum MfaPolicy {
  DISABLED
  OPTIONAL
  REQUIRED
}

enum MfaType {
  TOTP
}

// ─── Core Multi-Tenant ───

model Tenant {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  industry           String?
  scope              String?  @db.Text
  context            String?  @db.Text
  interestedParties  String?  @db.Text
  boundaries         String?  @db.Text
  exclusions         String?  @db.Text
  reminderDaysBefore Int      @default(14)
  maxRiskScale       Int      @default(5)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users             User[]
  memberships       TenantMembership[]
  clauseProgress    ClauseProgress[]
  tasks             Task[]
  taskLinks         TaskLink[]
  taskComments      TaskComment[]
  taskWatchers      TaskWatcher[]
  assets            Asset[]
  risks             Risk[]
  controls          Control[]
  evidence          Evidence[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  reminderHistories ReminderHistory[]
  policies          Policy[]
  audits            Audit[]
  findings          Finding[]
  controlContributors   ControlContributor[]
  controlTasks          ControlTask[]
  controlEvidenceLinks  ControlEvidenceLink[]
  riskControls          RiskControl[]
  controlAssets         ControlAsset[]
  assetRiskLinks        AssetRiskLink[]
  vendors               Vendor[]
  vendorContacts        VendorContact[]
  vendorDocuments       VendorDocument[]
  vendorAssessments     VendorAssessment[]
  vendorAssessmentAnswers VendorAssessmentAnswer[]
  vendorLinks           VendorLink[]
  vendorEvidenceBundles  VendorEvidenceBundle[]
  vendorEvidenceBundleItems VendorEvidenceBundleItem[]
  vendorRelationships   VendorRelationship[]
  controlRequirementLinks ControlRequirementLink[]
  auditCycles           AuditCycle[]
  auditPacks            AuditPack[]
  auditPackItems        AuditPackItem[]
  auditPackShares       AuditPackShare[]
  auditorAccounts       AuditorAccount[]
  controlTestPlans      ControlTestPlan[]
  controlTestRuns       ControlTestRun[]
  controlTestEvidenceLinks ControlTestEvidenceLink[]
  controlTestSteps      ControlTestStep[]
  fileRecords           FileRecord[]
  notificationOutbox    NotificationOutbox[]
  notificationSettings  TenantNotificationSettings?
  userNotificationPrefs UserNotificationPreference[]
  billingAccount        BillingAccount?
  billingEvents         BillingEvent[]
  onboarding            TenantOnboarding?
  riskSuggestionSessions RiskSuggestionSession[]
  riskSuggestionItems    RiskSuggestionItem[]
  policyVersions         PolicyVersion[]
  identityProviders      TenantIdentityProvider[]
  identityLinks          UserIdentityLink[]
  securitySettings       TenantSecuritySettings?
  mfaEnrollments         UserMfaEnrollment[]
  invites                TenantInvite[]
  scimTokens             TenantScimToken[]
  integrationConnections IntegrationConnection[]
  integrationExecutions  IntegrationExecution[]
  integrationWebhookEvents IntegrationWebhookEvent[]
}

// ─── Tenant Onboarding Wizard ───

model TenantOnboarding {
  id             String            @id @default(cuid())
  tenantId       String            @unique
  status         OnboardingStatus  @default(NOT_STARTED)
  currentStep    String            @default("COMPANY_PROFILE")
  completedSteps String[]          @default([])
  stepData       Json              @default("{}")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

// ─── Tenant Membership (user <-> tenant join with role) ───

model TenantMembership {
  id              String           @id @default(cuid())
  tenantId        String
  userId          String
  role            Role             @default(READER)
  status          MembershipStatus @default(ACTIVE)
  invitedByUserId String?
  invitedAt       DateTime?
  deactivatedAt   DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  user      User   @relation(fields: [userId], references: [id])
  invitedBy User?  @relation("MembershipInviter", fields: [invitedByUserId], references: [id])

  @@unique([tenantId, userId])
  @@index([tenantId, status])
}

model User {
  id            String    @id @default(cuid())
  tenantId      String? // @deprecated — use TenantMembership instead
  email         String    @unique
  emailEncrypted String?  @db.Text  // AES-256-GCM ciphertext of email
  emailHash      String?  @unique   // HMAC-SHA256 for login/lookup
  passwordHash  String?
  name          String?
  nameEncrypted  String?  @db.Text  // AES-256-GCM ciphertext of name
  emailVerified DateTime?
  image         String?
  role          Role      @default(READER) // @deprecated — use TenantMembership.role
  sessionVersion Int      @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant                 Tenant?                 @relation(fields: [tenantId], references: [id])
  tenantMemberships      TenantMembership[]
  accounts               Account[]
  sessions               AuthSession[]
  assignedTasks          Task[]                  @relation("TaskAssignee")
  createdTasks           Task[]                  @relation("TaskCreator")
  reviewingTasks         Task[]                  @relation("TaskReviewer")
  taskCommentsCreated    TaskComment[]            @relation("TaskCommentCreator")
  taskWatches            TaskWatcher[]
  evidenceReviews        EvidenceReview[]
  notifications          Notification[]
  policyApprovals            PolicyApproval[]         @relation("PolicyApprover")
  policyApprovalRequests     PolicyApproval[]         @relation("PolicyApprovalRequester")
  policyAcknowledgements     PolicyAcknowledgement[]
  policyVersionsCreated      PolicyVersion[]          @relation("PolicyVersionCreator")
  ownedPolicies              Policy[]                 @relation("PolicyOwner")
  auditLogs                       AuditLog[]
  controlApplicabilityDecisions   Control[]  @relation("ControlApplicabilityDecider")
  ownedControls                   Control[]  @relation("ControlOwner")
  createdControls                 Control[]  @relation("ControlCreator")
  controlContributions            ControlContributor[]
  controlTaskAssignments          ControlTask[] @relation("ControlTaskAssignee")
  controlEvidenceLinksCreated     ControlEvidenceLink[] @relation("ControlEvidenceCreator")
  ownedAssets                     Asset[]               @relation("AssetOwner")
  riskControlsCreated             RiskControl[]         @relation("RiskControlCreator")
  controlAssetsCreated            ControlAsset[]        @relation("ControlAssetCreator")
  assetRiskLinksCreated           AssetRiskLink[]       @relation("AssetRiskCreator")
  ownedVendors                    Vendor[]               @relation("VendorOwner")
  vendorDocsUploaded              VendorDocument[]        @relation("VendorDocUploader")
  assessmentsRequested            VendorAssessment[]     @relation("AssessmentRequester")
  assessmentsDecided              VendorAssessment[]     @relation("AssessmentDecider")
  vendorBundlesCreated            VendorEvidenceBundle[] @relation("EvidenceBundleCreator")
  auditCyclesCreated              AuditCycle[]
  auditPacksFrozen                AuditPack[]            @relation("AuditPackFrozenBy")
  auditSharesCreated              AuditPackShare[]
  ownedTestPlans                  ControlTestPlan[]      @relation("TestPlanOwner")
  createdTestPlans                ControlTestPlan[]      @relation("TestPlanCreator")
  executedTestRuns                ControlTestRun[]       @relation("TestRunExecutor")
  createdTestRuns                 ControlTestRun[]       @relation("TestRunCreator")
  testEvidenceLinksCreated        ControlTestEvidenceLink[] @relation("TestEvidenceCreator")
  uploadedFiles                   FileRecord[]              @relation("FileUploader")
  notificationPreferences         UserNotificationPreference[]
  riskSuggestionSessions          RiskSuggestionSession[]    @relation("SuggestionSessionCreator")
  identityLinks                   UserIdentityLink[]
  mfaEnrollments                  UserMfaEnrollment[]
  invitedMemberships              TenantMembership[]        @relation("MembershipInviter")
  invitesSent                     TenantInvite[]
}

// ─── Auth.js Models ───

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token           String? @db.Text
  access_token            String? @db.Text
  // Encrypted token columns (AES-256-GCM, populated by PII middleware)
  refreshTokenEncrypted   String? @db.Text
  accessTokenEncrypted    String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Clause Tracker ───

model Clause {
  id          String  @id @default(cuid())
  number      String  @unique // e.g., "4", "5.1", "6.1.2"
  title       String
  description String? @db.Text // Original paraphrase
  artifacts   String? @db.Text // Required outputs description
  sortOrder   Int     @default(0)

  progress ClauseProgress[]
}

model ClauseProgress {
  id        String       @id @default(cuid())
  tenantId  String
  clauseId  String
  status    ClauseStatus @default(NOT_STARTED)
  notes     String?      @db.Text
  updatedAt DateTime     @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  clause Clause @relation(fields: [clauseId], references: [id])

  @@unique([tenantId, clauseId])
}

// ─── Tasks (Unified Work Items) ───

model Task {
  id              String           @id @default(cuid())
  tenantId        String
  type            WorkItemType     @default(TASK)
  title           String
  description     String?          @db.Text
  severity        WorkItemSeverity @default(MEDIUM)
  priority        WorkItemPriority @default(P2)
  status          WorkItemStatus   @default(OPEN)
  source          WorkItemSource?  @default(MANUAL)
  key             String?          // human-friendly key like "TSK-123"
  resolution      String?          @db.Text
  dueAt           DateTime?
  completedAt     DateTime?        // set when RESOLVED/CLOSED/CANCELED
  createdByUserId String
  assigneeUserId  String?
  reviewerUserId  String?
  controlId       String?          // optional FK to Control
  metadataJson    Json?            // extensible metadata (findingSource, controlGapType, remediationPlan, etc.)
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  createdBy User    @relation("TaskCreator", fields: [createdByUserId], references: [id])
  assignee User?    @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  reviewer User?    @relation("TaskReviewer", fields: [reviewerUserId], references: [id])
  control  Control? @relation(fields: [controlId], references: [id])
  links    TaskLink[]
  comments TaskComment[]
  watchers TaskWatcher[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, severity])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, dueAt])
  @@index([tenantId, controlId])
  @@index([tenantId, deletedAt])
}

model TaskLink {
  id         String             @id @default(cuid())
  tenantId   String
  taskId     String
  entityType TaskLinkEntityType
  entityId   String
  relation   TaskLinkRelation   @default(RELATES_TO)
  createdAt  DateTime           @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([tenantId, taskId, entityType, entityId])
  @@index([tenantId, taskId])
}

model TaskComment {
  id              String   @id @default(cuid())
  tenantId        String
  taskId          String
  body            String   @db.Text
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  task      Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdBy User   @relation("TaskCommentCreator", fields: [createdByUserId], references: [id])

  @@index([tenantId, taskId])
}

model TaskWatcher {
  id       String @id @default(cuid())
  tenantId String
  taskId   String
  userId   String

  tenant Tenant @relation(fields: [tenantId], references: [id])
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([tenantId, taskId])
}

// ─── Assets ───

model Asset {
  id                String       @id @default(cuid())
  tenantId          String
  name              String
  type              AssetType
  classification    String?
  owner             String?
  ownerUserId       String?
  location          String?
  confidentiality   Int?         @default(3) // 1-5
  integrity         Int?         @default(3)
  availability      Int?         @default(3)
  criticality       Criticality?
  status            AssetStatus  @default(ACTIVE)
  externalRef       String?
  tags              String?      @db.Text // JSON array of strings
  dependencies      String?      @db.Text
  businessProcesses String?      @db.Text
  dataResidency     String?
  retention         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?
  retentionUntil    DateTime?

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  ownerUser   User?           @relation("AssetOwner", fields: [ownerUserId], references: [id])
  controls    ControlAsset[]
  risks       AssetRiskLink[]
  riskSuggestionItems RiskSuggestionItem[]

  @@index([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, criticality])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
}

// ─── Risks ───

model Risk {
  id              String             @id @default(cuid())
  tenantId        String
  title           String
  description     String?            @db.Text
  category        String?
  threat          String?
  vulnerability   String?            @db.Text
  likelihood      Int                @default(3)
  impact          Int                @default(3)
  score           Int                @default(9)
  inherentScore   Int                @default(9)
  status          RiskStatus         @default(OPEN)
  treatment       TreatmentDecision?
  treatmentOwner  String?
  treatmentNotes  String?            @db.Text
  ownerUserId     String?
  createdByUserId String?
  targetDate      DateTime?
  nextReviewAt    DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  controls RiskControl[]
  assetLinks AssetRiskLink[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, deletedAt])
}

model RiskTemplate {
  id                String   @id @default(cuid())
  title             String
  description       String?  @db.Text
  category          String?
  defaultLikelihood Int      @default(3)
  defaultImpact     Int      @default(3)
  frameworkTag      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── AI Risk Suggestions ───

model RiskSuggestionSession {
  id              String                  @id @default(cuid())
  tenantId        String
  createdByUserId String
  status          SuggestionSessionStatus @default(DRAFT)
  inputJson       String                  @db.Text // JSON: assets, frameworks, context
  modelName       String?                 // e.g., "gpt-4o", "claude-3.5-sonnet"
  provider        String                  @default("stub") // stub | openrouter
  errorMessage    String?                 @db.Text
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant    Tenant                 @relation(fields: [tenantId], references: [id])
  createdBy User                   @relation("SuggestionSessionCreator", fields: [createdByUserId], references: [id])
  items     RiskSuggestionItem[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model RiskSuggestionItem {
  id                    String                @id @default(cuid())
  sessionId             String
  tenantId              String
  assetId               String?
  title                 String
  description           String?               @db.Text
  category              String?
  threat                String?
  vulnerability         String?               @db.Text
  likelihoodSuggested   Int?
  impactSuggested       Int?
  rationale             String?               @db.Text
  suggestedControlsJson String?               @db.Text // JSON array of control themes
  status                SuggestionItemStatus  @default(PENDING)
  editedJson            String?               @db.Text // user edits before accepting
  createdRiskId         String?               // populated after ACCEPTED → Risk created
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  session Tenant                   @relation(fields: [tenantId], references: [id])
  suggestionSession RiskSuggestionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  asset   Asset?                   @relation(fields: [assetId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@index([tenantId, sessionId])
}

// ─── Controls ───

model Control {
  id            String         @id @default(cuid())
  tenantId      String? // null = global library control
  code          String? // e.g., "AC-01" — unique per tenant
  annexId       String?        @unique // e.g., "A.5.1" (legacy)
  name          String
  description   String?        @db.Text
  intent        String?        @db.Text
  category      String?
  status        ControlStatus  @default(NOT_STARTED)
  effectiveness Int? // 1-5
  lastTested    DateTime?
  reviewCadence ReviewCadence?
  isCustom      Boolean        @default(false)

  // ─── Ownership ───
  ownerUserId     String?
  createdByUserId String?

  // ─── Scheduling ───
  frequency     ControlFrequency?
  nextDueAt     DateTime?

  // ─── Evidence automation ───
  evidenceSource EvidenceSourceType?
  automationKey  String?  // integration check key

  // ─── Applicability (replaces scope-based filtering) ───
  applicability                Applicability @default(APPLICABLE)
  applicabilityJustification   String?       @db.Text
  applicabilityDecidedByUserId String?
  applicabilityDecidedAt       DateTime?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?

  tenant                 Tenant?             @relation(fields: [tenantId], references: [id])
  owner                  User?               @relation("ControlOwner", fields: [ownerUserId], references: [id])
  createdBy              User?               @relation("ControlCreator", fields: [createdByUserId], references: [id])
  applicabilityDecidedBy User?               @relation("ControlApplicabilityDecider", fields: [applicabilityDecidedByUserId], references: [id])
  risks                  RiskControl[]
  assets                 ControlAsset[]
  evidence               Evidence[]
  tasks              Task[]
  policyLinks            PolicyControlLink[]
  frameworkMappings      FrameworkMapping[]
  contributors           ControlContributor[]
  evidenceLinks          ControlEvidenceLink[]
  controlTasks           ControlTask[]
  requirementLinks       ControlRequirementLink[]
  testPlans              ControlTestPlan[]
  testRuns               ControlTestRun[]
  integrationExecutions  IntegrationExecution[]

  @@index([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, applicability])
  @@index([ownerUserId])
  @@index([nextDueAt])
  @@index([tenantId, deletedAt])
}

model RiskControl {
