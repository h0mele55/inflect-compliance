  tenantId         String
  type             EmailNotificationType
  toEmail          String
  subject          String
  bodyText         String
  bodyHtml         String?
  status           EmailOutboxStatus     @default(PENDING)
  attempts         Int                   @default(0)
  lastError        String?
  sendAfter        DateTime              @default(now())
  createdAt        DateTime              @default(now())
  sentAt           DateTime?
  dedupeKey        String                @unique
  toEmailEncrypted String?
  tenant           Tenant                @relation(fields: [tenantId], references: [id])

  @@index([status, sendAfter])
  @@index([tenantId])
}

model TenantNotificationSettings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  enabled           Boolean  @default(true)
  defaultFromName   String   @default("Inflect Compliance")
  defaultFromEmail  String   @default("noreply@inflect.app")
  complianceMailbox String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
}

model UserNotificationPreference {
  id        String               @id @default(cuid())
  userId    String
  tenantId  String
  delivery  NotificationDelivery @default(IMMEDIATE)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  tenant    Tenant               @relation(fields: [tenantId], references: [id])
  user      User                 @relation(fields: [userId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model BillingAccount {
  id                   String        @id @default(cuid())
  tenantId             String        @unique
  stripeCustomerId     String        @unique
  stripeSubscriptionId String?
  plan                 BillingPlan   @default(FREE)
  status               BillingStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  trialEndsAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  tenant               Tenant        @relation(fields: [tenantId], references: [id])
}

model BillingEvent {
  id            String   @id @default(cuid())
  tenantId      String
  type          String
  stripeEventId String   @unique
  payloadJson   Json
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

model TenantIdentityProvider {
  id            String               @id @default(cuid())
  tenantId      String
  type          IdentityProviderType
  name          String
  isEnabled     Boolean              @default(false)
  isEnforced    Boolean              @default(false)
  emailDomains  String[]             @default([])
  configJson    Json                 @default("{}")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  tenant        Tenant               @relation(fields: [tenantId], references: [id])
  identityLinks UserIdentityLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model UserIdentityLink {
  id                       String                 @id @default(cuid())
  userId                   String
  tenantId                 String
  providerId               String
  externalSubject          String
  emailAtLinkTime          String
  lastLoginAt              DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  emailAtLinkTimeEncrypted String?
  emailAtLinkTimeHash      String?
  provider                 TenantIdentityProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tenant                   Tenant                 @relation(fields: [tenantId], references: [id])
  user                     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalSubject])
  @@unique([userId, providerId])
  @@index([tenantId])
  @@index([userId])
}

model TenantSecuritySettings {
  id                   String    @id @default(cuid())
  tenantId             String    @unique
  mfaPolicy            MfaPolicy @default(DISABLED)
  sessionMaxAgeMinutes Int?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  mfaFailClosed        Boolean   @default(false)
  tenant               Tenant    @relation(fields: [tenantId], references: [id])
}

model UserMfaEnrollment {
  id                  String    @id @default(cuid())
  userId              String
  tenantId            String
  type                MfaType   @default(TOTP)
  secretEncrypted     String
  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?
  lastChallengeAt     DateTime?
  backupCodesHashJson String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id])
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId, type])
  @@index([userId])
  @@index([tenantId])
}

model TenantInvite {
  id          String    @id @default(cuid())
  tenantId    String
  email       String
  role        Role      @default(READER)
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  invitedBy   User      @relation(fields: [invitedById], references: [id])
  tenant      Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
  @@index([token])
  @@index([tenantId])
}

model TenantScimToken {
  id         String    @id @default(cuid())
  tenantId   String
  label      String
  tokenHash  String    @unique
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  tenant     Tenant    @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model IntegrationConnection {
  id              String                 @id @default(cuid())
  tenantId        String
  provider        String
  name            String
  isEnabled       Boolean                @default(true)
  configJson      Json                   @default("{}")
  secretEncrypted String?
  lastTestedAt    DateTime?
  lastTestStatus  String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  tenant          Tenant                 @relation(fields: [tenantId], references: [id])
  executions      IntegrationExecution[]

  @@unique([tenantId, provider, name])
  @@index([tenantId])
  @@index([tenantId, provider])
}

model IntegrationExecution {
  id            String                     @id @default(cuid())
  tenantId      String
  connectionId  String?
  provider      String
  automationKey String
  controlId     String?
  status        IntegrationExecutionStatus @default(PENDING)
  resultJson    Json?
  evidenceId    String?
  errorMessage  String?
  durationMs    Int?
  triggeredBy   String                     @default("scheduled")
  jobRunId      String?
  executedAt    DateTime                   @default(now())
  completedAt   DateTime?
  createdAt     DateTime                   @default(now())
  connection    IntegrationConnection?     @relation(fields: [connectionId], references: [id])
  control       Control?                   @relation(fields: [controlId], references: [id])
  tenant        Tenant                     @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, automationKey])
  @@index([tenantId, controlId])
  @@index([tenantId, status])
  @@index([jobRunId])
}

model IntegrationWebhookEvent {
  id           String    @id @default(cuid())
  tenantId     String?
  provider     String
  eventType    String?
  payloadJson  Json
  headersJson  Json?
  payloadHash  String?
  status       String    @default("received")
  errorMessage String?
  processedAt  DateTime?
  createdAt    DateTime  @default(now())
  receivedAt   DateTime  @default(now())
  tenant       Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([provider, receivedAt])
  @@index([provider, payloadHash, createdAt])
  @@index([status])
}

