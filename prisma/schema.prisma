generator client {
  provider      = "prisma-client-js"
  // linux-musl-openssl-3.0.x → Alpine 3.19+ / node:22-alpine runtime.
  // native → local dev. Both required for the image to run on any
  // target without regenerating.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Tenant {
  id                        String                       @id @default(cuid())
  name                      String
  slug                      String                       @unique
  /// Hub-and-spoke parent (Epic O-1). Nullable for backward compatibility:
  /// existing tenants migrated before the organization layer landed have
  /// no parent. New tenants created via `/api/org/{slug}/tenants` are
  /// always linked. ON DELETE SET NULL so removing an org doesn't take
  /// its tenants with it — orphaned tenants behave like the legacy
  /// pre-org model.
  organizationId            String?
  industry                  String?
  scope                     String?
  context                   String?
  interestedParties         String?
  boundaries                String?
  exclusions                String?
  reminderDaysBefore        Int                          @default(14)
  maxRiskScale              Int                          @default(5)
  /// Epic B.2 — wrapped per-tenant Data Encryption Key.
  /// Shape: the existing `encryptField()` envelope (`v1:base64(...)`),
  /// wrapping a 32-byte random DEK. See `src/lib/security/tenant-keys.ts`.
  /// Nullable so existing tenants continue working until the backfill
  /// script lands. The runtime integration phase may treat `NULL` as
  /// "use the global KEK directly" (current behaviour) or generate a
  /// DEK lazily on first use.
  encryptedDek              String?
  /// Epic B — previous wrapped DEK, retained during a per-tenant DEK
  /// rotation. Envelope: identical to `encryptedDek` — `v1:base64(...)`
  /// produced by `wrapDek()` from `src/lib/security/tenant-keys.ts`.
  ///
  /// Lifecycle: non-NULL only while a per-tenant DEK rotation is in
  /// flight (i.e. after a new DEK has been written to `encryptedDek`
  /// but before the background re-encryption job has finished
  /// rewriting every ciphertext that carried the old DEK). Once all
  /// v2:<old-dek>:... ciphertexts have been re-encrypted under the new
  /// DEK, the job clears this column back to NULL.
  ///
  /// Read-fallback: `getTenantDek` will try `encryptedDek` first and,
  /// on AES-GCM authentication failure, fall back to
  /// `previousEncryptedDek` — mirroring the master-KEK dual-key
  /// fallback in `decryptField`. (This fallback is reserved for the
  /// real implementation; the current `rotateTenantDek` stub throws.)
  ///
  /// Invariant: `previousEncryptedDek` must not equal `encryptedDek`
  /// when non-NULL. Equality would make the old and new DEKs
  /// indistinguishable on the decrypt path (silent key mixing). A DB
  /// CHECK constraint (`Tenant_previousEncryptedDek_differs`) enforces
  /// this at the storage layer so a rotation bug cannot silently
  /// produce identical values in both columns.
  previousEncryptedDek      String?
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  assets                    Asset[]
  assetRiskLinks            AssetRiskLink[]
  audits                    Audit[]
  auditCycles               AuditCycle[]
  auditLogs                 AuditLog[]
  auditPacks                AuditPack[]
  auditPackItems            AuditPackItem[]
  auditPackShares           AuditPackShare[]
  auditorAccounts           AuditorAccount[]
  billingAccount            BillingAccount?
  billingEvents             BillingEvent[]
  clauseProgress            ClauseProgress[]
  controls                  Control[]
  controlAssets             ControlAsset[]
  controlContributors       ControlContributor[]
  controlEvidenceLinks      ControlEvidenceLink[]
  controlRequirementLinks   ControlRequirementLink[]
  controlTasks              ControlTask[]
  controlTestEvidenceLinks  ControlTestEvidenceLink[]
  controlTestPlans          ControlTestPlan[]
  controlTestRuns           ControlTestRun[]
  controlTestSteps          ControlTestStep[]
  evidence                  Evidence[]
  fileRecords               FileRecord[]
  findings                  Finding[]
  integrationConnections    IntegrationConnection[]
  integrationExecutions     IntegrationExecution[]
  integrationWebhookEvents  IntegrationWebhookEvent[]
  notifications             Notification[]
  notificationOutbox        NotificationOutbox[]
  policies                  Policy[]
  policyVersions            PolicyVersion[]
  reminderHistories         ReminderHistory[]
  risks                     Risk[]
  riskControls              RiskControl[]
  riskSuggestionItems       RiskSuggestionItem[]
  riskSuggestionSessions    RiskSuggestionSession[]
  tasks                     Task[]
  taskComments              TaskComment[]
  taskLinks                 TaskLink[]
  taskWatchers              TaskWatcher[]
  identityProviders         TenantIdentityProvider[]
  invites                   TenantInvite[]
  memberships               TenantMembership[]
  notificationSettings      TenantNotificationSettings?
  onboarding                TenantOnboarding?
  scimTokens                TenantScimToken[]
  securitySettings          TenantSecuritySettings?
  identityLinks             UserIdentityLink[]
  mfaEnrollments            UserMfaEnrollment[]
  userNotificationPrefs     UserNotificationPreference[]
  vendors                   Vendor[]
  vendorAssessments         VendorAssessment[]
  vendorAssessmentAnswers   VendorAssessmentAnswer[]
  vendorContacts            VendorContact[]
  vendorDocuments           VendorDocument[]
  vendorEvidenceBundles     VendorEvidenceBundle[]
  vendorEvidenceBundleItems VendorEvidenceBundleItem[]
  vendorLinks               VendorLink[]
  vendorRelationships       VendorRelationship[]
  syncMappings              IntegrationSyncMapping[]
  customRoles               TenantCustomRole[]
  apiKeys                   TenantApiKey[]
  complianceSnapshots       ComplianceSnapshot[]
  automationRules           AutomationRule[]
  automationExecutions      AutomationExecution[]
  // denorm-tenantId Phase 1 inverse relations.
  evidenceReviews           EvidenceReview[]
  auditChecklistItems       AuditChecklistItem[]
  findingEvidences          FindingEvidence[]
  auditorPackAccesses       AuditorPackAccess[]
  // PolicyControlLink denormalisation (single-table follow-on).
  policyControlLinks        PolicyControlLink[]
  // Hub-and-spoke (Epic O-1).
  organization              Organization?                @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId])
}

// Hub-and-spoke organization layer (Epic O-1).
//
// An Organization is the parent of N tenants (typical: 100 solution-
// owner tenants per CISO portfolio). Org-level members come in two
// roles: ORG_ADMIN (CISO-class — gets auto-provisioned AUDITOR
// membership in every child tenant via the Epic O-2 service) and
// ORG_READER (portfolio-only, no per-tenant access).
//
// Slug is unique across the whole system, parallel to Tenant.slug.
// URL paths are `/org/{slug}` and `/t/{slug}` — the namespaces don't
// collide because the prefixes differ.
model Organization {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenants     Tenant[]
  memberships OrgMembership[]
  provisionedTenantMemberships TenantMembership[] @relation("OrgProvisionedTenantMemberships")
}

// Per-user, per-org role assignment.
//
// Two roles in the OrgRole enum: ORG_ADMIN, ORG_READER. ADMIN
// becoming a member triggers the Epic O-2 auto-provisioning service
// which creates an AUDITOR `TenantMembership` in every child tenant
// (idempotent — skips users who already have a manual membership).
//
// Removing an ORG_ADMIN triggers the deprovisioning service which
// deletes only auto-created memberships (the ones with
// `provisionedByOrgId` matching this org); manually-granted
// memberships are preserved.
model OrgMembership {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole      @default(ORG_READER)
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
}

model TenantOnboarding {
  id             String           @id @default(cuid())
  tenantId       String           @unique
  status         OnboardingStatus @default(NOT_STARTED)
  currentStep    String           @default("COMPANY_PROFILE")
  completedSteps String[]         @default([])
  stepData       Json             @default("{}")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
}

/// Tenant-scoped custom role with granular permission overrides.
/// Coexists with the built-in Role enum (ADMIN/EDITOR/READER/AUDITOR).
/// When a TenantMembership has a customRoleId, the permissionsJson from
/// this model takes precedence over the enum-based defaults for UI gating.
/// Backend authorization should merge/override accordingly.
model TenantCustomRole {
  id              String             @id @default(cuid())
  tenantId        String
  name            String /// Display name, e.g. "Compliance Lead"
  description     String? /// Optional description of the role's purpose
  baseRole        Role               @default(READER) /// Fallback enum role for coarse checks
  permissionsJson Json /// Typed PermissionSet — see src/lib/permissions.ts
  isActive        Boolean            @default(true) /// Soft-disable without deleting assignments
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  memberships     TenantMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

/// Tenant-scoped API keys for machine-to-machine authentication.
/// Keys are stored as SHA-256 hashes — the plaintext is shown only once at creation.
/// Supports expiry, revocation, scope restrictions, and last-used tracking.
model TenantApiKey {
  id          String    @id @default(cuid())
  tenantId    String
  name        String /// Human-friendly label, e.g. "CI/CD Pipeline"
  keyPrefix   String /// First 8 chars of the plaintext key (for identification)
  keyHash     String /// SHA-256 hash of the full plaintext key
  scopes      Json      @default("[]") /// JSON array of scope strings, e.g. ["controls:read","evidence:write"]
  expiresAt   DateTime? /// Optional expiry — null = no expiry
  revokedAt   DateTime? /// Non-null = revoked
  lastUsedAt  DateTime? /// Updated on each successful auth
  lastUsedIp  String? /// IP of last auth request
  createdById String /// User who created this key
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  createdBy   User      @relation("ApiKeyCreator", fields: [createdById], references: [id])

  @@unique([keyHash])
  @@index([tenantId])
  @@index([tenantId, revokedAt])
}

model TenantMembership {
  id                 String            @id @default(cuid())
  tenantId           String
  userId             String
  role               Role              @default(READER)
  customRoleId       String? /// Optional FK to TenantCustomRole for granular overrides
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deactivatedAt      DateTime?
  invitedAt          DateTime?
  invitedByUserId    String?
  status             MembershipStatus  @default(ACTIVE)
  /// Hub-and-spoke (Epic O-1). When non-NULL, this membership was
  /// auto-created by the org auto-provisioning service in response to
  /// the user gaining ORG_ADMIN on the named Organization. The
  /// deprovisioning service deletes ONLY rows with this column set,
  /// so manually-granted ADMIN/EDITOR/READER/AUDITOR memberships
  /// survive an ORG_ADMIN removal.
  ///
  /// NULL = manually created (the historical default, preserved for
  /// every membership that existed before the org layer landed).
  ///
  /// ON DELETE SET NULL on the Organization FK so deleting the parent
  /// org doesn't delete the auto-provisioned memberships — they
  /// transition to "manually created" semantics and are kept.
  /// (The deprovision usecase is the canonical cleanup path; the FK
  /// rule is referential-integrity defence-in-depth.)
  provisionedByOrgId String?
  customRole         TenantCustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  invitedBy          User?             @relation("MembershipInviter", fields: [invitedByUserId], references: [id])
  tenant             Tenant            @relation(fields: [tenantId], references: [id])
  user               User              @relation(fields: [userId], references: [id])
  provisionedByOrg   Organization?     @relation("OrgProvisionedTenantMemberships", fields: [provisionedByOrgId], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId, status])
  @@index([customRoleId])
  @@index([provisionedByOrgId])
}

model User {
  id                            String                       @id @default(cuid())
  email                         String                       @unique
  passwordHash                  String?
  name                          String?
  emailVerified                 DateTime?
  image                         String?
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  sessionVersion                Int                          @default(0)
  emailEncrypted                String?
  emailHash                     String?                      @unique
  nameEncrypted                 String?
  accounts                      Account[]
  ownedAssets                   Asset[]                      @relation("AssetOwner")
  assetRiskLinksCreated         AssetRiskLink[]              @relation("AssetRiskCreator")
  auditCyclesCreated            AuditCycle[]
  auditLogs                     AuditLog[]
  auditPacksFrozen              AuditPack[]                  @relation("AuditPackFrozenBy")
  auditSharesCreated            AuditPackShare[]
  controlApplicabilityDecisions Control[]                    @relation("ControlApplicabilityDecider")
  createdControls               Control[]                    @relation("ControlCreator")
  ownedControls                 Control[]                    @relation("ControlOwner")
  controlAssetsCreated          ControlAsset[]               @relation("ControlAssetCreator")
  controlContributions          ControlContributor[]
  controlEvidenceLinksCreated   ControlEvidenceLink[]        @relation("ControlEvidenceCreator")
  controlTaskAssignments        ControlTask[]                @relation("ControlTaskAssignee")
  testEvidenceLinksCreated      ControlTestEvidenceLink[]    @relation("TestEvidenceCreator")
  createdTestPlans              ControlTestPlan[]            @relation("TestPlanCreator")
  ownedTestPlans                ControlTestPlan[]            @relation("TestPlanOwner")
  createdTestRuns               ControlTestRun[]             @relation("TestRunCreator")
  executedTestRuns              ControlTestRun[]             @relation("TestRunExecutor")
  evidenceReviews               EvidenceReview[]
  ownedEvidence                 Evidence[]                   @relation("EvidenceOwner")
  uploadedFiles                 FileRecord[]                 @relation("FileUploader")
  notifications                 Notification[]
  ownedPolicies                 Policy[]                     @relation("PolicyOwner")
  policyAcknowledgements        PolicyAcknowledgement[]
  policyApprovals               PolicyApproval[]             @relation("PolicyApprover")
  policyApprovalRequests        PolicyApproval[]             @relation("PolicyApprovalRequester")
  policyVersionsCreated         PolicyVersion[]              @relation("PolicyVersionCreator")
  riskControlsCreated           RiskControl[]                @relation("RiskControlCreator")
  riskSuggestionSessions        RiskSuggestionSession[]      @relation("SuggestionSessionCreator")
  sessions                      AuthSession[]
  assignedTasks                 Task[]                       @relation("TaskAssignee")
  createdTasks                  Task[]                       @relation("TaskCreator")
  reviewingTasks                Task[]                       @relation("TaskReviewer")
  taskCommentsCreated           TaskComment[]                @relation("TaskCommentCreator")
  taskWatches                   TaskWatcher[]
  invitesSent                   TenantInvite[]
  invitedMemberships            TenantMembership[]           @relation("MembershipInviter")
  tenantMemberships             TenantMembership[]
  identityLinks                 UserIdentityLink[]
  mfaEnrollments                UserMfaEnrollment[]
  notificationPreferences       UserNotificationPreference[]
  ownedVendors                  Vendor[]                     @relation("VendorOwner")
  assessmentsDecided            VendorAssessment[]           @relation("AssessmentDecider")
  assessmentsRequested          VendorAssessment[]           @relation("AssessmentRequester")
  vendorDocsUploaded            VendorDocument[]             @relation("VendorDocUploader")
  vendorBundlesCreated          VendorEvidenceBundle[]       @relation("EvidenceBundleCreator")
  apiKeysCreated                TenantApiKey[]               @relation("ApiKeyCreator")
  userSessions                  UserSession[]                @relation("UserSessionOwner")
  orgMemberships                OrgMembership[]
}

model Account {
  id                    String  @id @default(cuid())
  userId                String
  type                  String
  provider              String
  providerAccountId     String
  refresh_token         String?
  access_token          String?
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?
  session_state         String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

// Epic C.3 — operational session tracking (separate from the
// NextAuth-adapter `AuthSession` table, which we leave untouched to
// avoid churning the adapter contract). One row per JWT minted by the
// `jwt` callback. Subsequent passes look this row up by `sessionId`,
// honour `revokedAt`, and update `lastActiveAt` (throttled).
//
// Privacy notes:
//   - `ipAddress` is captured from the incoming request at sign-in;
//     stored as a string (IPv4 / IPv6) so geo-IP correlation can
//     happen out-of-band. Acceptable under the existing PII model
//     because it's tied to the user's own auth event.
//   - `userAgent` is truncated to 512 chars to bound row size.
//   - Neither field is encrypted; both are operational telemetry,
//     not business content. If your threat model demands it, route
//     them through the encrypted-fields manifest later.
model UserSession {
  id            String    @id @default(cuid())
  /// Stable identifier embedded in the JWT so subsequent requests can
  /// find this row without trusting any other token claim. Min-entropy
  /// of cuid is acceptable; the token itself is signed by AUTH_SECRET
  /// so a guessed sessionId on its own does nothing.
  sessionId     String    @unique
  userId        String
  /// Tenant the user signed in against. Nullable because the very
  /// first JWT mint may precede tenant resolution (rare but possible).
  tenantId      String?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  lastActiveAt  DateTime  @default(now())
  revokedAt     DateTime?
  /// Free-form attribution for the revocation (e.g. "admin:abc123" or
  /// "user:self"). Not displayed to end users; surfaced in the audit
  /// log entry.
  revokedReason String?

  user User @relation("UserSessionOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([userId, revokedAt])
  @@index([tenantId, revokedAt])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Clause {
  id          String           @id @default(cuid())
  number      String           @unique
  title       String
  description String?
  artifacts   String?
  sortOrder   Int              @default(0)
  progress    ClauseProgress[]
}

model ClauseProgress {
  id        String       @id @default(cuid())
  tenantId  String
  clauseId  String
  status    ClauseStatus @default(NOT_STARTED)
  notes     String?
  updatedAt DateTime     @updatedAt
  clause    Clause       @relation(fields: [clauseId], references: [id])
  tenant    Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, clauseId])
}

model Task {
  id              String           @id @default(cuid())
  tenantId        String
  type            WorkItemType     @default(TASK)
  title           String
  description     String?
  severity        WorkItemSeverity @default(MEDIUM)
  priority        WorkItemPriority @default(P2)
  status          WorkItemStatus   @default(OPEN)
  source          WorkItemSource?  @default(MANUAL)
  key             String?
  resolution      String?
  dueAt           DateTime?
  completedAt     DateTime?
  createdByUserId String
  assigneeUserId  String?
  reviewerUserId  String?
  controlId       String?
  metadataJson    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  assignee        User?            @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  control         Control?         @relation(fields: [controlId], references: [id])
  createdBy       User             @relation("TaskCreator", fields: [createdByUserId], references: [id])
  reviewer        User?            @relation("TaskReviewer", fields: [reviewerUserId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  comments        TaskComment[]
  links           TaskLink[]
  watchers        TaskWatcher[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, severity])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, dueAt])
  @@index([tenantId, controlId])
  @@index([tenantId, deletedAt])
}

model TaskLink {
  id         String             @id @default(cuid())
  tenantId   String
  taskId     String
  entityType TaskLinkEntityType
  entityId   String
  relation   TaskLinkRelation   @default(RELATES_TO)
  createdAt  DateTime           @default(now())
  task       Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant     Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, taskId, entityType, entityId])
  @@index([tenantId, taskId])
}

model TaskComment {
  id              String   @id @default(cuid())
  tenantId        String
  taskId          String
  body            String
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       User     @relation("TaskCommentCreator", fields: [createdByUserId], references: [id])
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, taskId])
}

model TaskWatcher {
  id       String @id @default(cuid())
  tenantId String
  taskId   String
  userId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([tenantId, taskId])
}

model Asset {
  id                  String               @id @default(cuid())
  tenantId            String
  name                String
  type                AssetType
  classification      String?
  owner               String?
  location            String?
  confidentiality     Int?                 @default(3)
  integrity           Int?                 @default(3)
  availability        Int?                 @default(3)
  dependencies        String?
  businessProcesses   String?
  dataResidency       String?
  retention           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ownerUserId         String?
  criticality         Criticality?
  status              AssetStatus          @default(ACTIVE)
  externalRef         String?
  tags                String?
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?
  ownerUser           User?                @relation("AssetOwner", fields: [ownerUserId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  risks               AssetRiskLink[]
  controls            ControlAsset[]
  riskSuggestionItems RiskSuggestionItem[]

  @@index([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, criticality])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
}

model Risk {
  id              String             @id @default(cuid())
  tenantId        String
  title           String
  description     String?
  category        String?
  threat          String?
  vulnerability   String?
  likelihood      Int                @default(3)
  impact          Int                @default(3)
  score           Int                @default(9)
  inherentScore   Int                @default(9)
  status          RiskStatus         @default(OPEN)
  treatment       TreatmentDecision?
  treatmentOwner  String?
  treatmentNotes  String?
  ownerUserId     String?
  createdByUserId String?
  targetDate      DateTime?
  nextReviewAt    DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  assetLinks      AssetRiskLink[]
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  controls        RiskControl[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in RiskFilters
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `scoreMin`/`scoreMax` range filter
  @@index([tenantId, score])
  // GAP-perf — backs the default unpaginated `list()` orderBy:
  // `inherentScore desc`. Without this Postgres sorts the full
  // tenant result set per call.
  @@index([tenantId, inherentScore])
}

model RiskTemplate {
  id                String   @id @default(cuid())
  title             String
  description       String?
  category          String?
  defaultLikelihood Int      @default(3)
  defaultImpact     Int      @default(3)
  frameworkTag      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RiskSuggestionSession {
  id              String                  @id @default(cuid())
  tenantId        String
  createdByUserId String
  status          SuggestionSessionStatus @default(DRAFT)
  inputJson       String
  modelName       String?
  provider        String                  @default("stub")
  errorMessage    String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  items           RiskSuggestionItem[]
  createdBy       User                    @relation("SuggestionSessionCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model RiskSuggestionItem {
  id                    String                @id @default(cuid())
  sessionId             String
  tenantId              String
  assetId               String?
  title                 String
  description           String?
  category              String?
  threat                String?
  vulnerability         String?
  likelihoodSuggested   Int?
  impactSuggested       Int?
  rationale             String?
  suggestedControlsJson String?
  status                SuggestionItemStatus  @default(PENDING)
  editedJson            String?
  createdRiskId         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  asset                 Asset?                @relation(fields: [assetId], references: [id])
  suggestionSession     RiskSuggestionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  session               Tenant                @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@index([tenantId, sessionId])
}

model Control {
  id                           String                   @id @default(cuid())
  tenantId                     String?
  code                         String?
  annexId                      String?                  @unique
  name                         String
  description                  String?
  intent                       String?
  category                     String?
  status                       ControlStatus            @default(NOT_STARTED)
  effectiveness                Int?
  lastTested                   DateTime?
  reviewCadence                ReviewCadence?
  isCustom                     Boolean                  @default(false)
  ownerUserId                  String?
  createdByUserId              String?
  frequency                    ControlFrequency?
  nextDueAt                    DateTime?
  evidenceSource               EvidenceSourceType?
  automationKey                String?
  applicability                Applicability            @default(APPLICABLE)
  applicabilityJustification   String?
  applicabilityDecidedByUserId String?
  applicabilityDecidedAt       DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  deletedAt                    DateTime?
  deletedByUserId              String?
  retentionUntil               DateTime?
  applicabilityDecidedBy       User?                    @relation("ControlApplicabilityDecider", fields: [applicabilityDecidedByUserId], references: [id])
  createdBy                    User?                    @relation("ControlCreator", fields: [createdByUserId], references: [id])
  owner                        User?                    @relation("ControlOwner", fields: [ownerUserId], references: [id])
  tenant                       Tenant?                  @relation(fields: [tenantId], references: [id])
  assets                       ControlAsset[]
  contributors                 ControlContributor[]
  evidenceLinks                ControlEvidenceLink[]
  requirementLinks             ControlRequirementLink[]
  controlTasks                 ControlTask[]
  testPlans                    ControlTestPlan[]
  testRuns                     ControlTestRun[]
  evidence                     Evidence[]
  frameworkMappings            FrameworkMapping[]
  integrationExecutions        IntegrationExecution[]
  policyLinks                  PolicyControlLink[]
  risks                        RiskControl[]
  tasks                        Task[]

  @@index([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, applicability])
  @@index([ownerUserId])
  @@index([nextDueAt])
  @@index([tenantId, deletedAt])
  // GAP-perf — supports `ownerUserId` filter in tenant scope.
  // `[ownerUserId]` alone exists but isn't tenant-prefixed, so
  // Postgres can't selectively scan one tenant's slice for a
  // specific owner without an additional filter pass.
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `category` filter (free-text exact match).
  @@index([tenantId, category])
}

model RiskControl {
  id              String   @id @default(cuid())
  riskId          String
  controlId       String
  tenantId        String
  rationale       String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  control         Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("RiskControlCreator", fields: [createdByUserId], references: [id])
  risk            Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, riskId, controlId])
  @@index([tenantId])
}

model ControlAsset {
  id              String       @id @default(cuid())
  controlId       String
  assetId         String
  tenantId        String
  coverageType    CoverageType @default(UNKNOWN)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  control         Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation("ControlAssetCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, controlId, assetId])
  @@index([tenantId])
}

model AssetRiskLink {
  id              String        @id @default(cuid())
  tenantId        String
  assetId         String
  riskId          String
  exposureLevel   ExposureLevel @default(MEDIUM)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  asset           Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy       User?         @relation("AssetRiskCreator", fields: [createdByUserId], references: [id])
  risk            Risk          @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, assetId, riskId])
  @@index([tenantId])
}

model ControlContributor {
  id        String   @id @default(cuid())
  tenantId  String
  controlId String
  userId    String
  createdAt DateTime @default(now())
  control   Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([controlId, userId])
  @@index([tenantId])
}

model ControlTask {
  id             String            @id @default(cuid())
  tenantId       String
  controlId      String
  title          String
  description    String?
  status         ControlTaskStatus @default(OPEN)
  assigneeUserId String?
  dueAt          DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assignee       User?             @relation("ControlTaskAssignee", fields: [assigneeUserId], references: [id])
  control        Control           @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant         Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([controlId])
  @@index([status])
  @@index([dueAt])
  // GAP-perf — backs the dashboard "overdue tasks" query
  // (status IN ('OPEN','IN_PROGRESS') AND dueAt < now()) and the
  // refactored `runConsistencyCheck` overdue lookup. The
  // single-column `[status]` and `[dueAt]` indexes can't satisfy
  // the combined predicate efficiently.
  @@index([tenantId, status, dueAt])
}

model ControlEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  controlId           String
  kind                EvidenceLinkKind
  fileId              String?
  url                 String?
  integrationResultId String?
  note                String?
  createdByUserId     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  control             Control          @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy           User?            @relation("ControlEvidenceCreator", fields: [createdByUserId], references: [id])
  tenant              Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([controlId, kind, fileId])
  @@unique([controlId, kind, url])
  @@index([tenantId])
  @@index([controlId])
}

model ControlTemplate {
  id               String                           @id @default(cuid())
  code             String                           @unique
  title            String
  description      String?
  category         String?
  defaultFrequency ControlFrequency?
  defaultOwnerHint String?
  isGlobal         Boolean                          @default(true)
  createdAt        DateTime                         @default(now())
  requirementLinks ControlTemplateRequirementLink[]
  tasks            ControlTemplateTask[]
  packLinks        PackTemplateLink[]
}

model ControlTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  title       String
  description String?
  template    ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ControlTemplateRequirementLink {
  id            String               @id @default(cuid())
  templateId    String
  requirementId String
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  template      ControlTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, requirementId])
}

model Evidence {
  id                String                    @id @default(cuid())
  tenantId          String
  controlId         String?
  type              EvidenceType
  title             String
  content           String?
  fileName          String?
  fileSize          Int?
  category          String?
  dateCollected     DateTime                  @default(now())
  owner             String? // Legacy free-text — kept for backward compat
  ownerUserId       String? // Real user FK — used for due-item routing & notifications
  reviewCycle       ReviewCadence?
  nextReviewDate    DateTime?
  status            EvidenceStatus            @default(DRAFT)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?
  fileRecordId      String?
  expiredAt         DateTime?
  isArchived        Boolean                   @default(false)
  retentionDays     Int?
  retentionPolicy   RetentionPolicy           @default(NONE)
  retentionUntil    DateTime?
  testEvidenceLinks ControlTestEvidenceLink[]
  control           Control?                  @relation(fields: [controlId], references: [id])
  fileRecord        FileRecord?               @relation(fields: [fileRecordId], references: [id])
  ownerUser         User?                     @relation("EvidenceOwner", fields: [ownerUserId], references: [id])
  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
  reviews           EvidenceReview[]
  findingLinks      FindingEvidence[]
  reminderHistories ReminderHistory[]

  @@unique([id, tenantId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, retentionUntil])
  @@index([tenantId, isArchived])
  @@index([tenantId, ownerUserId])
  // GAP-perf — supports `status` filter (DRAFT|SUBMITTED|APPROVED|REJECTED).
  @@index([tenantId, status])
  // GAP-perf — supports `controlId` filter ("evidence for control X").
  // Already a heavily-used UI surface — every control detail page
  // pulls evidence by controlId.
  @@index([tenantId, controlId])
  // GAP-perf — supports `type` filter (FILE|LINK|TEXT|SCREENSHOT).
  @@index([tenantId, type])
}

model FileRecord {
  id               String           @id @default(cuid())
  tenantId         String
  pathKey          String           @unique
  originalName     String
  mimeType         String
  sizeBytes        Int
  sha256           String
  status           FileRecordStatus @default(PENDING)
  uploadedByUserId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  storedAt         DateTime?
  bucket           String?
  domain           String           @default("general")
  scanStatus       String           @default("PENDING")
  storageProvider  String           @default("local")
  scanDetails      String?
  scannedAt        DateTime?
  deletedAt        DateTime?
  deletedByUserId  String?
  retentionUntil   DateTime?
  evidence         Evidence[]
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  uploadedBy       User             @relation("FileUploader", fields: [uploadedByUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, scanStatus])
  @@index([tenantId, deletedAt])
}

model EvidenceReview {
  // denorm-tenantId — Phase 2: tenantId is NOT NULL and the parent
  // relation is composite (evidenceId, tenantId) → Evidence(id,
  // tenantId), which structurally guarantees this row's tenantId
  // matches its parent's. Phase 3 swaps the chained RLS policy for
  // the trivial direct form.
  id         String       @id @default(cuid())
  tenantId   String
  evidenceId String
  reviewerId String
  action     ReviewAction
  comment    String?
  createdAt  DateTime     @default(now())
  evidence   Evidence     @relation(fields: [evidenceId, tenantId], references: [id, tenantId], onDelete: Cascade)
  reviewer   User         @relation(fields: [reviewerId], references: [id])
  tenant     Tenant       @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, evidenceId])
}

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  entity       String
  entityId     String
  action       String
  details      String?
  createdAt    DateTime @default(now())
  metadataJson Json?
  recordIds    Json?
  requestId    String?
  diffJson     Json?
  actorType    String   @default("USER")
  detailsJson  Json?
  entryHash    String?
  previousHash String?
  version      Int      @default(1)
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, entity])
  @@index([tenantId, action])
  @@index([tenantId, entryHash])
}

model Notification {
