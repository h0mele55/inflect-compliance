  controlId     String
  requirementId String
  createdAt     DateTime             @default(now())
  control       Control              @relation(fields: [controlId], references: [id], onDelete: Cascade)
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  tenant        Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([controlId, requirementId])
  @@index([tenantId, requirementId])
}

model Vendor {
  id                  String                 @id @default(cuid())
  tenantId            String
  name                String
  legalName           String?
  websiteUrl          String?
  domain              String?
  country             String?
  description         String?
  ownerUserId         String?
  status              VendorStatus           @default(ONBOARDING)
  criticality         VendorCriticality      @default(MEDIUM)
  inherentRisk        VendorCriticality?
  residualRisk        VendorCriticality?
  nextReviewAt        DateTime?
  contractRenewalAt   DateTime?
  dataAccess          VendorDataAccess?
  isSubprocessor      Boolean                @default(false)
  tags                Json?
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  certificationsJson  Json?
  enrichmentLastRunAt DateTime?
  enrichmentStatus    String?
  privacyPolicyUrl    String?
  securityPageUrl     String?
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?
  owner               User?                  @relation("VendorOwner", fields: [ownerUserId], references: [id])
  tenant              Tenant                 @relation(fields: [tenantId], references: [id])
  assessments         VendorAssessment[]
  contacts            VendorContact[]
  documents           VendorDocument[]
  evidenceBundles     VendorEvidenceBundle[]
  links               VendorLink[]
