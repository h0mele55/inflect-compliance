// ─── Control Templates ───

model ControlTemplate {
  id               String            @id @default(cuid())
  code             String            @unique
  title            String
  description      String?           @db.Text
  category         String?
  defaultFrequency ControlFrequency?
  defaultOwnerHint String?
  isGlobal         Boolean           @default(true)
  createdAt        DateTime          @default(now())

  tasks             ControlTemplateTask[]
  requirementLinks  ControlTemplateRequirementLink[]
  packLinks         PackTemplateLink[]
}

model ControlTemplateTask {
  id          String  @id @default(cuid())
  templateId  String
  title       String
  description String? @db.Text

  template ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ControlTemplateRequirementLink {
  id            String @id @default(cuid())
  templateId    String
  requirementId String

  template    ControlTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  requirement FrameworkRequirement @relation(fields: [requirementId], references: [id])

  @@unique([templateId, requirementId])
}

// ─── Evidence ───

model Evidence {
  id             String         @id @default(cuid())
  tenantId       String
  controlId      String?
  type           EvidenceType
  title          String
  content        String?        @db.Text // text content or URL or file path
  fileName       String?
  fileSize       Int?
  category       String?
  dateCollected  DateTime       @default(now())
  owner          String?
  reviewCycle    ReviewCadence?
  nextReviewDate DateTime?
  status         EvidenceStatus @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt        DateTime?
  deletedByUserId  String?
  fileRecordId     String?
  retentionUntil   DateTime?
  retentionPolicy  RetentionPolicy @default(NONE)
  retentionDays    Int?
  isArchived       Boolean         @default(false)
  expiredAt        DateTime?

  tenant            Tenant            @relation(fields: [tenantId], references: [id])
  control           Control?          @relation(fields: [controlId], references: [id])
  fileRecord        FileRecord?       @relation(fields: [fileRecordId], references: [id])
  reviews           EvidenceReview[]
  reminderHistories ReminderHistory[]
  findingLinks      FindingEvidence[]
  testEvidenceLinks ControlTestEvidenceLink[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, retentionUntil])
  @@index([tenantId, isArchived])
}

// ─── File Records ───

model FileRecord {
  id               String           @id @default(cuid())
  tenantId         String
  pathKey          String           @unique
  originalName     String
  mimeType         String
  sizeBytes        Int
  sha256           String
  status           FileRecordStatus @default(PENDING)
  uploadedByUserId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  storedAt         DateTime?

  // ─── Cloud Storage Fields ───
  storageProvider  String           @default("local")  // "local" | "s3"
  bucket           String?                             // S3 bucket name (null for local)
  domain           String           @default("general") // evidence | reports | exports | temp | general
  scanStatus       String           @default("PENDING") // PENDING | CLEAN | INFECTED | SKIPPED
  scanDetails      String?          @db.Text            // AV scan result details (JSON)
  scannedAt        DateTime?                            // When scan completed

  deletedAt        DateTime?
  deletedByUserId  String?
  retentionUntil   DateTime?

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  uploadedBy User   @relation("FileUploader", fields: [uploadedByUserId], references: [id])
  evidence   Evidence[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, scanStatus])
  @@index([tenantId, deletedAt])
}

model EvidenceReview {
  id         String       @id @default(cuid())
  evidenceId String
  reviewerId String
  action     ReviewAction
  comment    String?      @db.Text
  createdAt  DateTime     @default(now())

  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  reviewer User     @relation(fields: [reviewerId], references: [id])
}

// ─── Audit Log ───

model AuditLog {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String?
  actorType    String   @default("USER") // USER | SYSTEM | JOB
  entity       String // e.g., "Asset", "Risk", "Control"
  entityId     String
  action       String // "CREATE", "UPDATE", "DELETE", "STATUS_CHANGE", "UPSERT", etc.
  details      String?  @db.Text          // Legacy free-form text (retained for backward compat)
  detailsJson  Json?                      // Structured canonical payload (replaces details)
  requestId    String?  // Correlation ID from request context
  recordIds    Json?    // For *Many operations: array of affected IDs or count metadata
  metadataJson Json?    // Structured context: { model, action, source, ... }
  diffJson     Json?    // For updates: { changedFields, before?, after? }
  previousHash String?                    // SHA-256 hex of previous entry's entryHash (per-tenant chain)
  entryHash    String?                    // SHA-256 hex of this entry's canonical form
  version      Int      @default(1)       // Schema version for forward-compat hashing
  createdAt    DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, entity])
  @@index([tenantId, action])
  @@index([tenantId, entryHash])
}

// ─── Notifications ───

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType @default(GENERAL)
  title     String
  message   String           @db.Text
  read      Boolean          @default(false)
  linkUrl   String?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
}

model ReminderHistory {
  id         String   @id @default(cuid())
  tenantId   String
  evidenceId String
  type       String // "DUE_SOON", "OVERDUE", "REJECTED"
  sentAt     DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  evidence Evidence @relation(fields: [evidenceId], references: [id])

  @@index([tenantId])
}

// ─── Policies ───

model Policy {
  id                   String       @id @default(cuid())
  tenantId             String
  slug                 String
  title                String
  description          String?      @db.Text
  category             String?
  status               PolicyStatus @default(DRAFT)
  currentVersionId     String?      @unique
  ownerUserId          String?
  reviewFrequencyDays  Int?
  nextReviewAt         DateTime?
  language             String?      @default("en")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  deletedAt            DateTime?
  deletedByUserId      String?
  retentionUntil       DateTime?

  tenant         Tenant              @relation(fields: [tenantId], references: [id])
  currentVersion PolicyVersion?      @relation("CurrentVersion", fields: [currentVersionId], references: [id])
  owner          User?               @relation("PolicyOwner", fields: [ownerUserId], references: [id])
  versions       PolicyVersion[]     @relation("PolicyVersions")
  approvals      PolicyApproval[]
  controlLinks   PolicyControlLink[]

  @@index([tenantId, slug])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([nextReviewAt])
  @@index([tenantId, deletedAt])
}

model PolicyVersion {
  id            String            @id @default(cuid())
  tenantId      String
  policyId      String
  versionNumber Int
  contentType   PolicyContentType @default(MARKDOWN)
  contentText   String?           @db.Text
  externalUrl   String?
  changeSummary String?
  createdById   String
  createdAt     DateTime          @default(now())

  tenant           Tenant                  @relation(fields: [tenantId], references: [id])
  policy           Policy                  @relation("PolicyVersions", fields: [policyId], references: [id], onDelete: Cascade)
  currentOfPolicy  Policy?                 @relation("CurrentVersion")
  createdBy        User                    @relation("PolicyVersionCreator", fields: [createdById], references: [id])
  approvals        PolicyApproval[]
  acknowledgements PolicyAcknowledgement[]

  @@unique([policyId, versionNumber])
  @@index([tenantId])
}

model PolicyApproval {
  id                String               @id @default(cuid())
  policyId          String
  policyVersionId   String
  requestedByUserId String
  approvedByUserId  String?
  status            PolicyApprovalStatus @default(PENDING)
  decidedAt         DateTime?
  comment           String?              @db.Text
  createdAt         DateTime             @default(now())

  policy        Policy        @relation(fields: [policyId], references: [id], onDelete: Cascade)
  policyVersion PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  requestedBy   User          @relation("PolicyApprovalRequester", fields: [requestedByUserId], references: [id])
  approvedBy    User?         @relation("PolicyApprover", fields: [approvedByUserId], references: [id])
}

model PolicyAcknowledgement {
  id              String   @id @default(cuid())
  policyVersionId String
  userId          String
  acknowledgedAt  DateTime @default(now())

  policyVersion PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])

  @@unique([policyVersionId, userId])
}

model PolicyControlLink {
  id        String @id @default(cuid())
  policyId  String
  controlId String

  policy  Policy  @relation(fields: [policyId], references: [id], onDelete: Cascade)
  control Control @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@unique([policyId, controlId])
}

// ─── Policy Templates ───

model PolicyTemplate {
  id          String            @id @default(cuid())
  title       String
  category    String?
  language    String?           @default("en")
  contentType PolicyContentType @default(MARKDOWN)
  contentText String            @db.Text
  tags        String?  // comma-separated tags
  isGlobal    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ─── Internal Audits ───

model Audit {
  id          String      @id @default(cuid())
  tenantId    String
  title       String
  auditScope  String?     @db.Text
  criteria    String?     @db.Text
  schedule    DateTime?
  auditors    String?
  auditees    String?
  departments String?
  status      AuditStatus @default(PLANNED)
  deletedAt    DateTime?
  deletedByUserId String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant    Tenant               @relation(fields: [tenantId], references: [id])
  checklist AuditChecklistItem[]
  findings  Finding[]


  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model AuditChecklistItem {
  id          String          @id @default(cuid())
  auditId     String
  prompt      String          @db.Text
  result      ChecklistResult @default(NOT_TESTED)
  notes       String?         @db.Text
  evidenceRef String?
  sortOrder   Int             @default(0)

  audit Audit @relation(fields: [auditId], references: [id], onDelete: Cascade)
}

// ─── Findings ───

model Finding {
  id                String          @id @default(cuid())
  tenantId          String
  auditId           String?
  severity          FindingSeverity
  type              FindingType
  title             String
  description       String          @db.Text
  rootCause         String?         @db.Text
  correctiveAction  String?         @db.Text
  owner             String?
  dueDate           DateTime?
  status            FindingStatus   @default(OPEN)
  verificationNotes String?         @db.Text
  verifiedBy        String?
  verifiedAt        DateTime?
  deletedAt         DateTime?
  deletedByUserId   String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  audit         Audit?            @relation(fields: [auditId], references: [id])

  evidenceLinks FindingEvidence[]

  @@index([tenantId])
  @@index([tenantId, deletedAt])
}

model FindingEvidence {
  id         String @id @default(cuid())
  findingId  String
  evidenceId String

  finding  Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)
  evidence Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@unique([findingId, evidenceId])
}

// ─── Framework Mapping ───

enum FrameworkKind {
  ISO_STANDARD
  EU_DIRECTIVE
}

model Framework {
  id           String                 @id @default(cuid())
  key          String                 @unique
  name         String                 // "ISO/IEC 27001"
  version      String?                // "2022"
  kind         FrameworkKind          @default(ISO_STANDARD)
  description  String?                @db.Text
  metadataJson String?                @db.Text
  createdAt    DateTime               @default(now())

  requirements FrameworkRequirement[]
  packs        FrameworkPack[]

  @@unique([key, version])
}

model FrameworkRequirement {
  id          String  @id @default(cuid())
  frameworkId String
  code        String // e.g., "5.1" for ISO27001 Annex A
  title       String
  description String? @db.Text
  section     String? // grouping: "Organizational Controls", "Article 21", "Clause 8"
  category    String? // e.g., "Security" for SOC2
  theme       String? // ORGANIZATIONAL | PEOPLE | PHYSICAL | TECHNOLOGICAL
  themeNumber Int?    // 5|6|7|8
  sortOrder   Int     @default(0)
  deprecatedAt DateTime? // soft delete: set when requirement removed in newer version

  framework    Framework          @relation(fields: [frameworkId], references: [id])
  mappingsFrom FrameworkMapping[] @relation("MappingFrom")
  mappingsTo   FrameworkMapping[] @relation("MappingTo")
  templateLinks ControlTemplateRequirementLink[]
  controlLinks  ControlRequirementLink[]

  @@unique([frameworkId, code])
}

model FrameworkPack {
  id            String  @id @default(cuid())
  key           String  @unique // "ISO27001_2022_BASE"
  name          String
  frameworkId   String
  version       String? // "2022"
  description   String? @db.Text
  createdAt     DateTime @default(now())

  framework     Framework @relation(fields: [frameworkId], references: [id])
  templateLinks PackTemplateLink[]
}

model PackTemplateLink {
  id         String @id @default(cuid())
  packId     String
  templateId String

  pack     FrameworkPack   @relation(fields: [packId], references: [id], onDelete: Cascade)
  template ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([packId, templateId])
}

model FrameworkMapping {
  id                String  @id @default(cuid())
  fromRequirementId String
  toRequirementId   String?
  toControlId       String?
  rationale         String? @db.Text

  fromRequirement FrameworkRequirement  @relation("MappingFrom", fields: [fromRequirementId], references: [id])
  toRequirement   FrameworkRequirement? @relation("MappingTo", fields: [toRequirementId], references: [id])
  toControl       Control?              @relation(fields: [toControlId], references: [id])

  @@unique([fromRequirementId, toControlId])
}

model ControlRequirementLink {
  id            String @id @default(cuid())
  tenantId      String
  controlId     String
  requirementId String
  createdAt     DateTime @default(now())

  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  control     Control             @relation(fields: [controlId], references: [id], onDelete: Cascade)
  requirement FrameworkRequirement @relation(fields: [requirementId], references: [id])

  @@unique([controlId, requirementId])
  @@index([tenantId, requirementId])
}

// ─── Issue Management ───

// ─── Issue models removed — data migrated to Task ───
// DB tables preserved for rollback safety. See migration: migrate_issues_to_tasks

// ═══════════════════════════════════════════════════════════════════
// ─── Vendor Management ───
// ═══════════════════════════════════════════════════════════════════

enum VendorStatus {
  ACTIVE
  ONBOARDING
  OFFBOARDING
  OFFBOARDED
}

enum VendorCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum VendorDataAccess {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum VendorDocumentType {
  CONTRACT
  SOC2
  ISO_CERT
  DPA
  SECURITY_POLICY
  PEN_TEST
  OTHER
}

enum AnswerType {
  YES_NO
  SINGLE_SELECT
  MULTI_SELECT
  TEXT
  NUMBER
}

enum AssessmentStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

enum VendorLinkEntityType {
  ASSET
  RISK
  ISSUE
  CONTROL
}

enum VendorLinkRelation {
  USES
  STORES_DATA_FOR
  PROVIDES_SERVICE_TO
  MITIGATES
  RELATED
}

model Vendor {
  id                String            @id @default(cuid())
  tenantId          String
  name              String
  legalName         String?
  websiteUrl        String?
  domain            String?
  country           String?
  description       String?           @db.Text
  ownerUserId       String?
  status            VendorStatus      @default(ONBOARDING)
  criticality       VendorCriticality @default(MEDIUM)
  inherentRisk      VendorCriticality?
  residualRisk      VendorCriticality?
  nextReviewAt      DateTime?
  contractRenewalAt DateTime?
  dataAccess        VendorDataAccess?
  isSubprocessor    Boolean           @default(false)
  tags              Json?             // string[]
  privacyPolicyUrl  String?
  securityPageUrl   String?
  certificationsJson Json?            // string[] e.g. ["SOC2","ISO27001"]
  enrichmentLastRunAt DateTime?
  enrichmentStatus  String?           // PENDING | SUCCESS | FAILED | NOT_RUN
  deletedAt         DateTime?
  deletedByUserId   String?
  retentionUntil    DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  owner       User?              @relation("VendorOwner", fields: [ownerUserId], references: [id])
  contacts         VendorContact[]
  documents        VendorDocument[]
  assessments      VendorAssessment[]
  links            VendorLink[]
  evidenceBundles  VendorEvidenceBundle[]
  subprocessorOf   VendorRelationship[] @relation("SubprocessorRelation")
  primaryOf        VendorRelationship[] @relation("PrimaryRelation")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, criticality])
  @@index([tenantId, nextReviewAt])
  @@index([tenantId, contractRenewalAt])
  @@index([tenantId, deletedAt])
}

model VendorContact {
  id               String   @id @default(cuid())
  tenantId         String
  vendorId         String
  name             String
  nameEncrypted    String?  @db.Text  // AES-256-GCM
  email            String?
  emailEncrypted   String?  @db.Text  // AES-256-GCM
  emailHash        String?            // HMAC-SHA256 for lookup
  title            String?
  phone            String?
  phoneEncrypted   String?  @db.Text  // AES-256-GCM
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([tenantId, vendorId])
}

model VendorDocument {
  id               String             @id @default(cuid())
  tenantId         String
  vendorId         String
  type             VendorDocumentType
  fileId           String?
  externalUrl      String?
  title            String?
  validFrom        DateTime?
  validTo          DateTime?
  notes            String?            @db.Text
  uploadedByUserId String
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  vendor     Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation("VendorDocUploader", fields: [uploadedByUserId], references: [id])

  @@index([tenantId, vendorId])
  @@index([tenantId, vendorId, type])
  @@index([tenantId, validTo])
}

model QuestionnaireTemplate {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?  @db.Text
  version     Int      @default(1)
  isGlobal    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   QuestionnaireQuestion[]
  assessments VendorAssessment[]
}

model QuestionnaireQuestion {
  id             String     @id @default(cuid())
  templateId     String
  section        String
  prompt         String     @db.Text
  answerType     AnswerType
  optionsJson    Json?      // string[] for select types
  weight         Float      @default(1)
  riskPointsJson Json?      // { "YES": 0, "NO": 10 } etc
  required       Boolean    @default(true)
  sortOrder      Int        @default(0)

  template QuestionnaireTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers  VendorAssessmentAnswer[]

  @@index([templateId, section, sortOrder])
}

model VendorAssessment {
  id                String           @id @default(cuid())
  tenantId          String
  vendorId          String
  templateId        String
  status            AssessmentStatus @default(DRAFT)
  startedAt         DateTime         @default(now())
  submittedAt       DateTime?
  decidedAt         DateTime?
  requestedByUserId String
  decidedByUserId   String?
  score             Float?
  riskRating        VendorCriticality?
  notes             String?          @db.Text
  nextReviewAt      DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant      Tenant                @relation(fields: [tenantId], references: [id])
  vendor      Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  template    QuestionnaireTemplate @relation(fields: [templateId], references: [id])
  requestedBy User                  @relation("AssessmentRequester", fields: [requestedByUserId], references: [id])
  decidedBy   User?                 @relation("AssessmentDecider", fields: [decidedByUserId], references: [id])
  answers     VendorAssessmentAnswer[]

  @@index([tenantId, vendorId])
  @@index([tenantId, status])
  @@index([tenantId, riskRating])
}

model VendorAssessmentAnswer {
  id              String   @id @default(cuid())
  tenantId        String
  assessmentId    String
  questionId      String
  answerJson      Json     // The actual answer value
  computedPoints  Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant                @relation(fields: [tenantId], references: [id])
  assessment VendorAssessment      @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   QuestionnaireQuestion @relation(fields: [questionId], references: [id])

  @@unique([assessmentId, questionId])
  @@index([tenantId, assessmentId])
}

model VendorLink {
  id         String               @id @default(cuid())
  tenantId   String
  vendorId   String
  entityType VendorLinkEntityType
  entityId   String
  relation   VendorLinkRelation   @default(RELATED)
  createdAt  DateTime             @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, vendorId, entityType, entityId])
  @@index([tenantId, vendorId])
}

model VendorEvidenceBundle {
  id              String   @id @default(cuid())
  tenantId        String
  vendorId        String
  name            String
  description     String?  @db.Text
  frozenAt        DateTime?
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  vendor    Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("EvidenceBundleCreator", fields: [createdByUserId], references: [id])
  items     VendorEvidenceBundleItem[]

  @@index([tenantId, vendorId])
}

model VendorEvidenceBundleItem {
  id         String   @id @default(cuid())
  bundleId   String
  tenantId   String
  entityType String   // VENDOR_DOCUMENT | ASSESSMENT | EVIDENCE | CONTROL
  entityId   String
  snapshotJson Json?  // frozen copy of metadata at bundle-freeze time
  createdAt  DateTime @default(now())

  bundle VendorEvidenceBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  tenant Tenant               @relation(fields: [tenantId], references: [id])

  @@unique([bundleId, entityType, entityId])
  @@index([tenantId, bundleId])
}

model VendorRelationship {
  id                   String   @id @default(cuid())
  tenantId             String
  primaryVendorId      String
  subprocessorVendorId String
  purpose              String?  @db.Text
  dataTypes            String?  // comma-separated or JSON
  country              String?
  createdAt            DateTime @default(now())

  tenant       Tenant @relation(fields: [tenantId], references: [id])
  primary      Vendor @relation("PrimaryRelation", fields: [primaryVendorId], references: [id], onDelete: Cascade)
  subprocessor Vendor @relation("SubprocessorRelation", fields: [subprocessorVendorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, primaryVendorId, subprocessorVendorId])
  @@index([tenantId, primaryVendorId])
}

// ─── Audit Readiness ───

enum AuditCycleStatus {
  PLANNING
  IN_PROGRESS
  READY
  COMPLETE
}

enum AuditPackStatus {
  DRAFT
  FROZEN
  EXPORTED
}

enum AuditorStatus {
  INVITED
  ACTIVE
  REVOKED
}

enum AuditPackItemEntityType {
  CONTROL
  POLICY
  EVIDENCE
  FILE
  ISSUE
  READINESS_REPORT
  FRAMEWORK_COVERAGE
  TEST_RUN
}

model AuditCycle {
  id               String           @id @default(cuid())
  tenantId         String
  frameworkKey      String           // ISO27001 | NIS2
  frameworkVersion  String           // "2022" | "EU_2022_2555"
  name             String
  periodStartAt    DateTime?
  periodEndAt      DateTime?
  status           AuditCycleStatus @default(PLANNING)
  createdByUserId  String
  deletedAt        DateTime?
  deletedByUserId  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  createdBy User        @relation(fields: [createdByUserId], references: [id])
  packs     AuditPack[]

  @@index([tenantId, frameworkKey, status])
  @@index([tenantId, deletedAt])
}

model AuditPack {
  id             String          @id @default(cuid())
  tenantId       String
  auditCycleId   String
  name           String
  status         AuditPackStatus @default(DRAFT)
  frozenAt       DateTime?
  frozenByUserId String?
  notes          String?         @db.Text
  deletedAt       DateTime?
  deletedByUserId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  cycle     AuditCycle      @relation(fields: [auditCycleId], references: [id])
  frozenBy  User?           @relation("AuditPackFrozenBy", fields: [frozenByUserId], references: [id])
  items     AuditPackItem[]
  shares    AuditPackShare[]
  auditorAccess AuditorPackAccess[]

  @@index([tenantId, auditCycleId])
  @@index([tenantId, deletedAt])
}

model AuditPackItem {
  id           String                  @id @default(cuid())
  tenantId     String
  auditPackId  String
  entityType   AuditPackItemEntityType
  entityId     String
  snapshotJson String                  @db.Text  // JSON snapshot
  sortOrder    Int                     @default(0)
  createdAt    DateTime                @default(now())

  tenant Tenant    @relation(fields: [tenantId], references: [id])
  pack   AuditPack @relation(fields: [auditPackId], references: [id], onDelete: Cascade)

  @@unique([auditPackId, entityType, entityId])
  @@index([tenantId, auditPackId])
}

model AuditPackShare {
  id              String    @id @default(cuid())
  tenantId        String
  auditPackId     String
  tokenHash       String    // SHA-256 hash only
  expiresAt       DateTime?
  createdByUserId String
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  pack      AuditPack @relation(fields: [auditPackId], references: [id])
  createdBy User      @relation(fields: [createdByUserId], references: [id])

  @@index([tokenHash])
  @@index([tenantId, auditPackId])
}

model AuditorAccount {
  id               String        @id @default(cuid())
  tenantId         String
  email            String
  emailEncrypted   String?       @db.Text  // AES-256-GCM
  emailHash        String?                 // HMAC-SHA256 for lookup
  name             String?
  nameEncrypted    String?       @db.Text  // AES-256-GCM
  status           AuditorStatus @default(INVITED)
  createdAt        DateTime      @default(now())

  tenant     Tenant              @relation(fields: [tenantId], references: [id])
  packAccess AuditorPackAccess[]

  @@unique([tenantId, email])
  @@index([emailHash])
}

model AuditorPackAccess {
  id          String   @id @default(cuid())
  auditorId   String
  auditPackId String
  grantedAt   DateTime @default(now())

  auditor AuditorAccount @relation(fields: [auditorId], references: [id])
  pack    AuditPack      @relation(fields: [auditPackId], references: [id])

  @@unique([auditorId, auditPackId])
}

// ─── Control Tests (Test-of-Control) ───

model ControlTestPlan {
  id                String           @id @default(cuid())
  tenantId          String
  controlId         String
  name              String
  description       String?          @db.Text
  method            TestMethod       @default(MANUAL)
  frequency         ControlFrequency @default(AD_HOC)
  nextDueAt         DateTime?
  ownerUserId       String?
  expectedEvidence  Json?
  status            TestPlanStatus   @default(ACTIVE)
  createdByUserId   String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  control   Control  @relation(fields: [controlId], references: [id])
  owner     User?    @relation("TestPlanOwner", fields: [ownerUserId], references: [id])
  createdBy User     @relation("TestPlanCreator", fields: [createdByUserId], references: [id])
  runs      ControlTestRun[]
  steps     ControlTestStep[]

  @@index([tenantId])
  @@index([tenantId, controlId])
  @@index([tenantId, nextDueAt])
  @@index([tenantId, status])
}

model ControlTestRun {
  id               String        @id @default(cuid())
  tenantId         String
  controlId        String
  testPlanId       String
  status           TestRunStatus @default(PLANNED)
  result           TestResult?
  executedAt       DateTime?
  executedByUserId String?
  notes            String?       @db.Text
  findingSummary   String?       @db.Text
  createdByUserId  String
  requestId        String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  control    Control               @relation(fields: [controlId], references: [id])
  testPlan   ControlTestPlan       @relation(fields: [testPlanId], references: [id])
  executedBy User?                 @relation("TestRunExecutor", fields: [executedByUserId], references: [id])
  createdBy  User                  @relation("TestRunCreator", fields: [createdByUserId], references: [id])
  evidence   ControlTestEvidenceLink[]

  @@index([tenantId])
  @@index([tenantId, testPlanId])
  @@index([tenantId, result])
  @@index([tenantId, executedAt])
}

model ControlTestEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  testRunId           String
  kind                TestEvidenceKind
  fileId              String?
  evidenceId          String?
  url                 String?
  integrationResultId String?
  sha256Hash          String?
  note                String?          @db.Text
  createdByUserId     String
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id])
  testRun   ControlTestRun  @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  evidence  Evidence?       @relation(fields: [evidenceId], references: [id])
  createdBy User            @relation("TestEvidenceCreator", fields: [createdByUserId], references: [id])

  @@unique([testRunId, kind, evidenceId])
  @@unique([testRunId, kind, fileId])
  @@index([tenantId])
  @@index([tenantId, testRunId])
}

model ControlTestStep {
  id             String   @id @default(cuid())
  tenantId       String
  testPlanId     String
  sortOrder      Int      @default(0)
  instruction    String   @db.Text
  expectedOutput String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  testPlan ControlTestPlan @relation(fields: [testPlanId], references: [id], onDelete: Cascade)

  @@index([tenantId, testPlanId])
}

// ─── Email Notification Outbox ───

model NotificationOutbox {
  id                String                 @id @default(cuid())
  tenantId          String
  type              EmailNotificationType
  toEmail           String
  toEmailEncrypted  String?                @db.Text  // AES-256-GCM
  subject           String
  bodyText          String                 @db.Text
  bodyHtml          String?                @db.Text
  status            EmailOutboxStatus      @default(PENDING)
  attempts          Int                    @default(0)
  lastError         String?                @db.Text
  sendAfter         DateTime               @default(now())
  createdAt         DateTime               @default(now())
  sentAt            DateTime?
  dedupeKey         String                 @unique  // tenantId:type:email:entityId:YYYY-MM-DD

  tenant     Tenant @relation(fields: [tenantId], references: [id])

  @@index([status, sendAfter])
  @@index([tenantId])
}

// ─── Notification Settings ───

model TenantNotificationSettings {
  id                String   @id @default(cuid())
  tenantId          String   @unique
  enabled           Boolean  @default(true)
  defaultFromName   String   @default("Inflect Compliance")
  defaultFromEmail  String   @default("noreply@inflect.app")
  complianceMailbox String?              // BCC for compliance team
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant   @relation(fields: [tenantId], references: [id])
}

model UserNotificationPreference {
  id        String               @id @default(cuid())
  userId    String
  tenantId  String
  delivery  NotificationDelivery @default(IMMEDIATE)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user      User   @relation(fields: [userId], references: [id])
  tenant    Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId])
  @@index([tenantId])
}

// ─── Billing ───

enum BillingPlan {
  FREE
  TRIAL
  PRO
  ENTERPRISE
}

enum BillingStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  TRIALING
}

model BillingAccount {
  id                    String        @id @default(cuid())
  tenantId              String        @unique
  stripeCustomerId      String        @unique
  stripeSubscriptionId  String?
  plan                  BillingPlan   @default(FREE)
  status                BillingStatus @default(ACTIVE)
  currentPeriodEnd      DateTime?
  trialEndsAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model BillingEvent {
  id            String   @id @default(cuid())
  tenantId      String
  type          String
  stripeEventId String   @unique
  payloadJson   Json
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
}

// ─── Enterprise SSO: Tenant Identity Providers ───

model TenantIdentityProvider {
  id           String                @id @default(cuid())
  tenantId     String
  type         IdentityProviderType
  name         String                // Human-readable name: "Okta", "Azure AD", etc.
  isEnabled    Boolean               @default(false)
  isEnforced   Boolean               @default(false) // When true, local login is disabled for this tenant
  emailDomains String[]              @default([])
  configJson   Json                  @default("{}") // IdP-specific config (metadata URL, client ID, etc.)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  tenant        Tenant              @relation(fields: [tenantId], references: [id])
  identityLinks UserIdentityLink[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

// ─── Enterprise SSO: External Identity Links ───

model UserIdentityLink {
  id                          String    @id @default(cuid())
  userId                      String
  tenantId                    String
  providerId                  String
  externalSubject             String    // IdP's unique subject identifier (SAML NameID / OIDC sub claim)
  emailAtLinkTime             String    // Email address at time of first SSO login
  emailAtLinkTimeEncrypted    String?   @db.Text  // AES-256-GCM
  emailAtLinkTimeHash         String?             // HMAC-SHA256 for lookup
  lastLoginAt                 DateTime?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  user     User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant   Tenant                 @relation(fields: [tenantId], references: [id])
  provider TenantIdentityProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, externalSubject])
  @@unique([userId, providerId])
  @@index([tenantId])
  @@index([userId])
}

// ─── MFA & Session Security ───

model TenantSecuritySettings {
  id                    String    @id @default(cuid())
  tenantId              String    @unique
  mfaPolicy             MfaPolicy @default(DISABLED)
  mfaFailClosed         Boolean   @default(false)
  sessionMaxAgeMinutes  Int?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model UserMfaEnrollment {
  id                  String    @id @default(cuid())
  userId              String
  tenantId            String
  type                MfaType   @default(TOTP)
  secretEncrypted     String    @db.Text
  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?
  lastChallengeAt     DateTime?
  backupCodesHashJson String?   @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([userId, tenantId, type])
  @@index([userId])
  @@index([tenantId])
}

// ─── Tenant Invitations ───

model TenantInvite {
  id          String    @id @default(cuid())
  tenantId    String
  email       String
  role        Role      @default(READER)
  token       String    @unique  // URL-safe random token
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  invitedBy User   @relation(fields: [invitedById], references: [id])

  @@unique([tenantId, email])
  @@index([token])
  @@index([tenantId])
}

// ─── SCIM Provisioning Tokens ───

model TenantScimToken {
  id          String    @id @default(cuid())
  tenantId    String
  label       String    // Human-readable label: "Okta SCIM", "Azure AD Provisioning"
  tokenHash   String    @unique  // SHA-256 hash of the bearer token
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ─── Integration Framework ───

enum IntegrationExecutionStatus {
  PENDING
  RUNNING
  PASSED
  FAILED
  ERROR
}

model IntegrationConnection {
  id               String   @id @default(cuid())
  tenantId         String
  provider         String   // e.g. "github", "aws", "azure"
  name             String   // Human-readable: "Acme GitHub Org"
  isEnabled        Boolean  @default(true)
  configJson       Json     @default("{}")
  secretEncrypted  String?  @db.Text  // AES-256-GCM encrypted credentials
  lastTestedAt     DateTime?
  lastTestStatus   String?  // "ok" | "error" | null
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  executions IntegrationExecution[]

  @@unique([tenantId, provider, name])
  @@index([tenantId])
  @@index([tenantId, provider])
}

model IntegrationExecution {
  id               String                     @id @default(cuid())
  tenantId         String
  connectionId     String?
  provider         String                     // e.g. "github"
  automationKey    String                     // e.g. "github.branch_protection"
  controlId        String?
  status           IntegrationExecutionStatus @default(PENDING)
  resultJson       Json?                      // provider-specific result payload
  evidenceId       String?                    // if evidence was auto-created
  errorMessage     String?    @db.Text
  durationMs       Int?
  triggeredBy      String     @default("scheduled") // "scheduled" | "manual" | "webhook"
  jobRunId         String?                    // correlates cron batch runs
  executedAt       DateTime   @default(now())
  completedAt      DateTime?
  createdAt        DateTime   @default(now())

  tenant     Tenant                @relation(fields: [tenantId], references: [id])
  connection IntegrationConnection? @relation(fields: [connectionId], references: [id])
  control    Control?              @relation(fields: [controlId], references: [id])

  @@index([tenantId])
  @@index([tenantId, automationKey])
  @@index([tenantId, controlId])
  @@index([tenantId, status])
  @@index([jobRunId])
}

model IntegrationWebhookEvent {
  id            String    @id @default(cuid())
  tenantId      String?
  provider      String    // e.g. "github"
  eventType     String?   // e.g. "push", "branch_protection_rule"
  payloadJson   Json      // raw webhook body
  headersJson   Json?     // selected headers for verification replay
  payloadHash   String?   // SHA-256 of raw body for replay deduplication
  status        String    @default("received") // "received" | "processed" | "ignored" | "error"
  errorMessage  String?   @db.Text
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  receivedAt    DateTime  @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([provider, receivedAt])
  @@index([provider, payloadHash, createdAt]) // dedup lookup
  @@index([status])
}
