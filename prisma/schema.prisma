generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Tenant {
  id                        String                       @id @default(cuid())
  name                      String
  slug                      String                       @unique
  industry                  String?
  scope                     String?
  context                   String?
  interestedParties         String?
  boundaries                String?
  exclusions                String?
  reminderDaysBefore        Int                          @default(14)
  maxRiskScale              Int                          @default(5)
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  assets                    Asset[]
  assetRiskLinks            AssetRiskLink[]
  audits                    Audit[]
  auditCycles               AuditCycle[]
  auditLogs                 AuditLog[]
  auditPacks                AuditPack[]
  auditPackItems            AuditPackItem[]
  auditPackShares           AuditPackShare[]
  auditorAccounts           AuditorAccount[]
  billingAccount            BillingAccount?
  billingEvents             BillingEvent[]
  clauseProgress            ClauseProgress[]
  controls                  Control[]
  controlAssets             ControlAsset[]
  controlContributors       ControlContributor[]
  controlEvidenceLinks      ControlEvidenceLink[]
  controlRequirementLinks   ControlRequirementLink[]
  controlTasks              ControlTask[]
  controlTestEvidenceLinks  ControlTestEvidenceLink[]
  controlTestPlans          ControlTestPlan[]
  controlTestRuns           ControlTestRun[]
  controlTestSteps          ControlTestStep[]
  evidence                  Evidence[]
  fileRecords               FileRecord[]
  findings                  Finding[]
  integrationConnections    IntegrationConnection[]
  integrationExecutions     IntegrationExecution[]
  integrationWebhookEvents  IntegrationWebhookEvent[]
  notifications             Notification[]
  notificationOutbox        NotificationOutbox[]
  policies                  Policy[]
  policyVersions            PolicyVersion[]
  reminderHistories         ReminderHistory[]
  risks                     Risk[]
  riskControls              RiskControl[]
  riskSuggestionItems       RiskSuggestionItem[]
  riskSuggestionSessions    RiskSuggestionSession[]
  tasks                     Task[]
  taskComments              TaskComment[]
  taskLinks                 TaskLink[]
  taskWatchers              TaskWatcher[]
  identityProviders         TenantIdentityProvider[]
  invites                   TenantInvite[]
  memberships               TenantMembership[]
  notificationSettings      TenantNotificationSettings?
  onboarding                TenantOnboarding?
  scimTokens                TenantScimToken[]
  securitySettings          TenantSecuritySettings?
  users                     User[]
  identityLinks             UserIdentityLink[]
  mfaEnrollments            UserMfaEnrollment[]
  userNotificationPrefs     UserNotificationPreference[]
  vendors                   Vendor[]
  vendorAssessments         VendorAssessment[]
  vendorAssessmentAnswers   VendorAssessmentAnswer[]
  vendorContacts            VendorContact[]
  vendorDocuments           VendorDocument[]
  vendorEvidenceBundles     VendorEvidenceBundle[]
  vendorEvidenceBundleItems VendorEvidenceBundleItem[]
  vendorLinks               VendorLink[]
  vendorRelationships       VendorRelationship[]
}

model TenantOnboarding {
  id             String           @id @default(cuid())
  tenantId       String           @unique
  status         OnboardingStatus @default(NOT_STARTED)
  currentStep    String           @default("COMPANY_PROFILE")
  completedSteps String[]         @default([])
  stepData       Json             @default("{}")
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
}

model TenantMembership {
  id              String           @id @default(cuid())
  tenantId        String
  userId          String
  role            Role             @default(READER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deactivatedAt   DateTime?
  invitedAt       DateTime?
  invitedByUserId String?
  status          MembershipStatus @default(ACTIVE)
  invitedBy       User?            @relation("MembershipInviter", fields: [invitedByUserId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  user            User             @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId])
  @@index([tenantId, status])
}

model User {
  id                            String                       @id @default(cuid())
  tenantId                      String?
  email                         String                       @unique
  passwordHash                  String?
  name                          String?
  emailVerified                 DateTime?
  image                         String?
  role                          Role                         @default(READER)
  createdAt                     DateTime                     @default(now())
  updatedAt                     DateTime                     @updatedAt
  sessionVersion                Int                          @default(0)
  emailEncrypted                String?
  emailHash                     String?                      @unique
  nameEncrypted                 String?
  accounts                      Account[]
  ownedAssets                   Asset[]                      @relation("AssetOwner")
  assetRiskLinksCreated         AssetRiskLink[]              @relation("AssetRiskCreator")
  auditCyclesCreated            AuditCycle[]
  auditLogs                     AuditLog[]
  auditPacksFrozen              AuditPack[]                  @relation("AuditPackFrozenBy")
  auditSharesCreated            AuditPackShare[]
  controlApplicabilityDecisions Control[]                    @relation("ControlApplicabilityDecider")
  createdControls               Control[]                    @relation("ControlCreator")
  ownedControls                 Control[]                    @relation("ControlOwner")
  controlAssetsCreated          ControlAsset[]               @relation("ControlAssetCreator")
  controlContributions          ControlContributor[]
  controlEvidenceLinksCreated   ControlEvidenceLink[]        @relation("ControlEvidenceCreator")
  controlTaskAssignments        ControlTask[]                @relation("ControlTaskAssignee")
  testEvidenceLinksCreated      ControlTestEvidenceLink[]    @relation("TestEvidenceCreator")
  createdTestPlans              ControlTestPlan[]            @relation("TestPlanCreator")
  ownedTestPlans                ControlTestPlan[]            @relation("TestPlanOwner")
  createdTestRuns               ControlTestRun[]             @relation("TestRunCreator")
  executedTestRuns              ControlTestRun[]             @relation("TestRunExecutor")
  evidenceReviews               EvidenceReview[]
  uploadedFiles                 FileRecord[]                 @relation("FileUploader")
  notifications                 Notification[]
  ownedPolicies                 Policy[]                     @relation("PolicyOwner")
  policyAcknowledgements        PolicyAcknowledgement[]
  policyApprovals               PolicyApproval[]             @relation("PolicyApprover")
  policyApprovalRequests        PolicyApproval[]             @relation("PolicyApprovalRequester")
  policyVersionsCreated         PolicyVersion[]              @relation("PolicyVersionCreator")
  riskControlsCreated           RiskControl[]                @relation("RiskControlCreator")
  riskSuggestionSessions        RiskSuggestionSession[]      @relation("SuggestionSessionCreator")
  sessions                      AuthSession[]
  assignedTasks                 Task[]                       @relation("TaskAssignee")
  createdTasks                  Task[]                       @relation("TaskCreator")
  reviewingTasks                Task[]                       @relation("TaskReviewer")
  taskCommentsCreated           TaskComment[]                @relation("TaskCommentCreator")
  taskWatches                   TaskWatcher[]
  invitesSent                   TenantInvite[]
  invitedMemberships            TenantMembership[]           @relation("MembershipInviter")
  tenantMemberships             TenantMembership[]
  tenant                        Tenant?                      @relation(fields: [tenantId], references: [id])
  identityLinks                 UserIdentityLink[]
  mfaEnrollments                UserMfaEnrollment[]
  notificationPreferences       UserNotificationPreference[]
  ownedVendors                  Vendor[]                     @relation("VendorOwner")
  assessmentsDecided            VendorAssessment[]           @relation("AssessmentDecider")
  assessmentsRequested          VendorAssessment[]           @relation("AssessmentRequester")
  vendorDocsUploaded            VendorDocument[]             @relation("VendorDocUploader")
  vendorBundlesCreated          VendorEvidenceBundle[]       @relation("EvidenceBundleCreator")
}

model Account {
  id                    String  @id @default(cuid())
  userId                String
  type                  String
  provider              String
  providerAccountId     String
  refresh_token         String?
  access_token          String?
  expires_at            Int?
  token_type            String?
  scope                 String?
  id_token              String?
  session_state         String?
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Clause {
  id          String           @id @default(cuid())
  number      String           @unique
  title       String
  description String?
  artifacts   String?
  sortOrder   Int              @default(0)
  progress    ClauseProgress[]
}

model ClauseProgress {
  id        String       @id @default(cuid())
  tenantId  String
  clauseId  String
  status    ClauseStatus @default(NOT_STARTED)
  notes     String?
  updatedAt DateTime     @updatedAt
  clause    Clause       @relation(fields: [clauseId], references: [id])
  tenant    Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, clauseId])
}

model Task {
  id              String           @id @default(cuid())
  tenantId        String
  type            WorkItemType     @default(TASK)
  title           String
  description     String?
  severity        WorkItemSeverity @default(MEDIUM)
  priority        WorkItemPriority @default(P2)
  status          WorkItemStatus   @default(OPEN)
  source          WorkItemSource?  @default(MANUAL)
  key             String?
  resolution      String?
  dueAt           DateTime?
  completedAt     DateTime?
  createdByUserId String
  assigneeUserId  String?
  reviewerUserId  String?
  controlId       String?
  metadataJson    Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  assignee        User?            @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  control         Control?         @relation(fields: [controlId], references: [id])
  createdBy       User             @relation("TaskCreator", fields: [createdByUserId], references: [id])
  reviewer        User?            @relation("TaskReviewer", fields: [reviewerUserId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  comments        TaskComment[]
  links           TaskLink[]
  watchers        TaskWatcher[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, severity])
  @@index([tenantId, assigneeUserId])
  @@index([tenantId, dueAt])
  @@index([tenantId, controlId])
  @@index([tenantId, deletedAt])
}

model TaskLink {
  id         String             @id @default(cuid())
  tenantId   String
  taskId     String
  entityType TaskLinkEntityType
  entityId   String
  relation   TaskLinkRelation   @default(RELATES_TO)
  createdAt  DateTime           @default(now())
  task       Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant     Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, taskId, entityType, entityId])
  @@index([tenantId, taskId])
}

model TaskComment {
  id              String   @id @default(cuid())
  tenantId        String
  taskId          String
  body            String
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       User     @relation("TaskCommentCreator", fields: [createdByUserId], references: [id])
  task            Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, taskId])
}

model TaskWatcher {
  id       String @id @default(cuid())
  tenantId String
  taskId   String
  userId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  user     User   @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([tenantId, taskId])
}

model Asset {
  id                  String               @id @default(cuid())
  tenantId            String
  name                String
  type                AssetType
  classification      String?
  owner               String?
  location            String?
  confidentiality     Int?                 @default(3)
  integrity           Int?                 @default(3)
  availability        Int?                 @default(3)
  dependencies        String?
  businessProcesses   String?
  dataResidency       String?
  retention           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  ownerUserId         String?
  criticality         Criticality?
  status              AssetStatus          @default(ACTIVE)
  externalRef         String?
  tags                String?
  deletedAt           DateTime?
  deletedByUserId     String?
  retentionUntil      DateTime?
  ownerUser           User?                @relation("AssetOwner", fields: [ownerUserId], references: [id])
  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  risks               AssetRiskLink[]
  controls            ControlAsset[]
  riskSuggestionItems RiskSuggestionItem[]

  @@index([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, type])
  @@index([tenantId, criticality])
  @@index([tenantId, status])
  @@index([tenantId, deletedAt])
}

model Risk {
  id              String             @id @default(cuid())
  tenantId        String
  title           String
  description     String?
  category        String?
  threat          String?
  vulnerability   String?
  likelihood      Int                @default(3)
  impact          Int                @default(3)
  score           Int                @default(9)
  inherentScore   Int                @default(9)
  status          RiskStatus         @default(OPEN)
  treatment       TreatmentDecision?
  treatmentOwner  String?
  treatmentNotes  String?
  ownerUserId     String?
  createdByUserId String?
  targetDate      DateTime?
  nextReviewAt    DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?
  deletedByUserId String?
  retentionUntil  DateTime?
  assetLinks      AssetRiskLink[]
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  controls        RiskControl[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, category])
  @@index([tenantId, deletedAt])
}

model RiskTemplate {
  id                String   @id @default(cuid())
  title             String
  description       String?
  category          String?
  defaultLikelihood Int      @default(3)
  defaultImpact     Int      @default(3)
  frameworkTag      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model RiskSuggestionSession {
  id              String                  @id @default(cuid())
  tenantId        String
  createdByUserId String
  status          SuggestionSessionStatus @default(DRAFT)
  inputJson       String
  modelName       String?
  provider        String                  @default("stub")
  errorMessage    String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  items           RiskSuggestionItem[]
  createdBy       User                    @relation("SuggestionSessionCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant                  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model RiskSuggestionItem {
  id                    String                @id @default(cuid())
  sessionId             String
  tenantId              String
  assetId               String?
  title                 String
  description           String?
  category              String?
  threat                String?
  vulnerability         String?
  likelihoodSuggested   Int?
  impactSuggested       Int?
  rationale             String?
  suggestedControlsJson String?
  status                SuggestionItemStatus  @default(PENDING)
  editedJson            String?
  createdRiskId         String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  asset                 Asset?                @relation(fields: [assetId], references: [id])
  suggestionSession     RiskSuggestionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  session               Tenant                @relation(fields: [tenantId], references: [id])

  @@index([sessionId])
  @@index([tenantId])
  @@index([tenantId, sessionId])
}

model Control {
  id                           String                   @id @default(cuid())
  tenantId                     String?
  code                         String?
  annexId                      String?                  @unique
  name                         String
  description                  String?
  intent                       String?
  category                     String?
  status                       ControlStatus            @default(NOT_STARTED)
  effectiveness                Int?
  lastTested                   DateTime?
  reviewCadence                ReviewCadence?
  isCustom                     Boolean                  @default(false)
  ownerUserId                  String?
  createdByUserId              String?
  frequency                    ControlFrequency?
  nextDueAt                    DateTime?
  evidenceSource               EvidenceSourceType?
  automationKey                String?
  applicability                Applicability            @default(APPLICABLE)
  applicabilityJustification   String?
  applicabilityDecidedByUserId String?
  applicabilityDecidedAt       DateTime?
  createdAt                    DateTime                 @default(now())
  updatedAt                    DateTime                 @updatedAt
  deletedAt                    DateTime?
  deletedByUserId              String?
  retentionUntil               DateTime?
  applicabilityDecidedBy       User?                    @relation("ControlApplicabilityDecider", fields: [applicabilityDecidedByUserId], references: [id])
  createdBy                    User?                    @relation("ControlCreator", fields: [createdByUserId], references: [id])
  owner                        User?                    @relation("ControlOwner", fields: [ownerUserId], references: [id])
  tenant                       Tenant?                  @relation(fields: [tenantId], references: [id])
  assets                       ControlAsset[]
  contributors                 ControlContributor[]
  evidenceLinks                ControlEvidenceLink[]
  requirementLinks             ControlRequirementLink[]
  controlTasks                 ControlTask[]
  testPlans                    ControlTestPlan[]
  testRuns                     ControlTestRun[]
  evidence                     Evidence[]
  frameworkMappings            FrameworkMapping[]
  integrationExecutions        IntegrationExecution[]
  policyLinks                  PolicyControlLink[]
  risks                        RiskControl[]
  tasks                        Task[]

  @@index([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, applicability])
  @@index([ownerUserId])
  @@index([nextDueAt])
  @@index([tenantId, deletedAt])
}

model RiskControl {
  id              String   @id @default(cuid())
  riskId          String
  controlId       String
  tenantId        String
  rationale       String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  control         Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?    @relation("RiskControlCreator", fields: [createdByUserId], references: [id])
  risk            Risk     @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, riskId, controlId])
  @@index([tenantId])
}

model ControlAsset {
  id              String       @id @default(cuid())
  controlId       String
  assetId         String
  tenantId        String
  coverageType    CoverageType @default(UNKNOWN)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime     @default(now())
  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  control         Control      @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy       User?        @relation("ControlAssetCreator", fields: [createdByUserId], references: [id])
  tenant          Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, controlId, assetId])
  @@index([tenantId])
}

model AssetRiskLink {
  id              String        @id @default(cuid())
  tenantId        String
  assetId         String
  riskId          String
  exposureLevel   ExposureLevel @default(MEDIUM)
  rationale       String?
  createdByUserId String?
  createdAt       DateTime      @default(now())
  asset           Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdBy       User?         @relation("AssetRiskCreator", fields: [createdByUserId], references: [id])
  risk            Risk          @relation(fields: [riskId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, assetId, riskId])
  @@index([tenantId])
}

model ControlContributor {
  id        String   @id @default(cuid())
  tenantId  String
  controlId String
  userId    String
  createdAt DateTime @default(now())
  control   Control  @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([controlId, userId])
  @@index([tenantId])
}

model ControlTask {
  id             String            @id @default(cuid())
  tenantId       String
  controlId      String
  title          String
  description    String?
  status         ControlTaskStatus @default(OPEN)
  assigneeUserId String?
  dueAt          DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  assignee       User?             @relation("ControlTaskAssignee", fields: [assigneeUserId], references: [id])
  control        Control           @relation(fields: [controlId], references: [id], onDelete: Cascade)
  tenant         Tenant            @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([controlId])
  @@index([status])
  @@index([dueAt])
}

model ControlEvidenceLink {
  id                  String           @id @default(cuid())
  tenantId            String
  controlId           String
  kind                EvidenceLinkKind
  fileId              String?
  url                 String?
  integrationResultId String?
  note                String?
  createdByUserId     String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  control             Control          @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdBy           User?            @relation("ControlEvidenceCreator", fields: [createdByUserId], references: [id])
  tenant              Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([controlId, kind, fileId])
  @@unique([controlId, kind, url])
  @@index([tenantId])
  @@index([controlId])
}

model ControlTemplate {
  id               String                           @id @default(cuid())
  code             String                           @unique
  title            String
  description      String?
  category         String?
  defaultFrequency ControlFrequency?
  defaultOwnerHint String?
  isGlobal         Boolean                          @default(true)
  createdAt        DateTime                         @default(now())
  requirementLinks ControlTemplateRequirementLink[]
  tasks            ControlTemplateTask[]
  packLinks        PackTemplateLink[]
}

model ControlTemplateTask {
  id          String          @id @default(cuid())
  templateId  String
  title       String
  description String?
  template    ControlTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ControlTemplateRequirementLink {
  id            String               @id @default(cuid())
  templateId    String
  requirementId String
  requirement   FrameworkRequirement @relation(fields: [requirementId], references: [id])
  template      ControlTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, requirementId])
}

model Evidence {
  id                String                    @id @default(cuid())
  tenantId          String
  controlId         String?
  type              EvidenceType
  title             String
  content           String?
  fileName          String?
  fileSize          Int?
  category          String?
  dateCollected     DateTime                  @default(now())
  owner             String?
  reviewCycle       ReviewCadence?
  nextReviewDate    DateTime?
  status            EvidenceStatus            @default(DRAFT)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
  deletedAt         DateTime?
  deletedByUserId   String?
  fileRecordId      String?
  expiredAt         DateTime?
  isArchived        Boolean                   @default(false)
  retentionDays     Int?
  retentionPolicy   RetentionPolicy           @default(NONE)
  retentionUntil    DateTime?
  testEvidenceLinks ControlTestEvidenceLink[]
  control           Control?                  @relation(fields: [controlId], references: [id])
  fileRecord        FileRecord?               @relation(fields: [fileRecordId], references: [id])
  tenant            Tenant                    @relation(fields: [tenantId], references: [id])
  reviews           EvidenceReview[]
  findingLinks      FindingEvidence[]
  reminderHistories ReminderHistory[]

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, deletedAt])
  @@index([tenantId, retentionUntil])
  @@index([tenantId, isArchived])
}

model FileRecord {
  id               String           @id @default(cuid())
  tenantId         String
  pathKey          String           @unique
  originalName     String
  mimeType         String
  sizeBytes        Int
  sha256           String
  status           FileRecordStatus @default(PENDING)
  uploadedByUserId String
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  storedAt         DateTime?
  bucket           String?
  domain           String           @default("general")
  scanStatus       String           @default("PENDING")
  storageProvider  String           @default("local")
  scanDetails      String?
  scannedAt        DateTime?
  deletedAt        DateTime?
  deletedByUserId  String?
  retentionUntil   DateTime?
  evidence         Evidence[]
  tenant           Tenant           @relation(fields: [tenantId], references: [id])
  uploadedBy       User             @relation("FileUploader", fields: [uploadedByUserId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, scanStatus])
  @@index([tenantId, deletedAt])
}

model EvidenceReview {
  id         String       @id @default(cuid())
  evidenceId String
  reviewerId String
  action     ReviewAction
  comment    String?
  createdAt  DateTime     @default(now())
  evidence   Evidence     @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
