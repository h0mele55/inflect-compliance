  tenant       Tenant?   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([provider, receivedAt])
  @@index([provider, payloadHash, createdAt])
  @@index([status])
}

// Note: @@map is deliberately omitted here to conform to the repository's 
// global Prisma convention. All models use Prisma's default exact-case tables
// (e.g., 'IntegrationSyncMapping' instead of 'integration_sync_mappings').
// The isolated AuthSession model mapped strictly to "Session" remains an anomaly.
model IntegrationSyncMapping {
  id                String                 @id @default(cuid())
  tenantId          String
  provider          String
  connectionId      String?
  localEntityType   String
  localEntityId     String
  remoteEntityType  String
  remoteEntityId    String
  syncStatus        SyncStatus             @default(PENDING)
  lastSyncDirection SyncDirection?
  conflictStrategy  ConflictStrategy       @default(REMOTE_WINS)
  localUpdatedAt    DateTime?
  remoteUpdatedAt   DateTime?
  remoteDataJson    Json?
  version           Int                    @default(1)
  errorMessage      String?
  lastSyncedAt      DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  connection        IntegrationConnection? @relation(fields: [connectionId], references: [id])
  tenant            Tenant                 @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, provider, localEntityType, localEntityId])
  @@unique([tenantId, provider, remoteEntityType, remoteEntityId])
  @@index([tenantId, provider])
  @@index([tenantId, syncStatus])
  @@index([connectionId])
}

enum Role {
  /// OWNER — tenant lifecycle (delete tenant, rotate DEK, transfer
  /// ownership) + owner management (invite/remove OWNERs, assign OWNER
  /// role). Strictly superset of ADMIN. The last ACTIVE OWNER of a
  /// tenant cannot be removed or demoted (DB trigger + usecase guard).
