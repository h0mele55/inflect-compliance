# =============================================================================
# inflect-compliance — Observability Stack environment.
# -----------------------------------------------------------------------------
# Copy to .env and edit. NEVER commit the real .env.
#   cp .env.example .env
#
# Consumed by:
#   docker compose -f docker-compose.observability.yml --env-file .env up -d
# =============================================================================

# --- Networking --------------------------------------------------------------
# The docker network created by the APP's compose project. This stack joins it
# as an external network so the app's `app` container can reach `otel-collector`
# by DNS. Find the real name with `docker network ls` — it is usually
# "<app-compose-project>_internal" (the app compose declares a bridge network
# literally named `internal`). Example: inflect_internal
APP_NETWORK_NAME=inflect_internal

# --- Environment label -------------------------------------------------------
# Stamped onto every metric + trace as the `deployment.environment` resource
# attribute. Use: local | staging | production
DEPLOYMENT_ENVIRONMENT=production

# --- Trace sampling ----------------------------------------------------------
# Head-sampling percentage applied by the collector's probabilistic_sampler.
# 100 = keep every trace, 20 = keep ~1 in 5. Lower it under high load.
OTEL_SAMPLING_PERCENTAGE=20

# --- Prometheus --------------------------------------------------------------
# TSDB retention window (--storage.tsdb.retention.time). e.g. 15d, 30d, 90d.
PROM_RETENTION=30d

# Remote-write target (OPTIONAL). Only needed if you uncomment the
# remote_write block in prometheus/prometheus.yml. Leave blank otherwise.
# PROM_REMOTE_WRITE_URL=
# PROM_REMOTE_WRITE_USERNAME=
# PROM_REMOTE_WRITE_PASSWORD=

# --- Tempo -------------------------------------------------------------------
# Trace retention window (compactor block_retention). e.g. 24h, 168h, 720h.
TEMPO_RETENTION=168h

# --- Grafana -----------------------------------------------------------------
# Admin login. CHANGE THE PASSWORD before first start — the container refuses
# to start if GF_SECURITY_ADMIN_PASSWORD is unset.
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change-me

# Public root URL once Grafana is fronted by Caddy. Used for share links,
# OAuth redirects, and alert callbacks. e.g. https://grafana.example.com
GF_SERVER_ROOT_URL=http://localhost:3001

# --- Alerting ----------------------------------------------------------------
# Generic webhook target for the provisioned Grafana contact point
# (Slack/PagerDuty/Opsgenie ingest URL, etc.). Leave blank to provision the
# contact point with a no-op URL — alerts evaluate but are not delivered.
GRAFANA_ALERT_WEBHOOK=
