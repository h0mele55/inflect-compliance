# Terraform working state — never commit
.terraform/
.terraform.lock.hcl.bak

# State files — must live in remote backend (S3), never on disk
*.tfstate
*.tfstate.*
*.tfstate.backup

# Plan outputs — may contain secrets resolved from data sources
*.tfplan
*.tfplan.*

# Crash logs
crash.log
crash.*.log

# CLI overrides — local-only escape hatches must not be shared
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Secrets — committed envs/*.tfvars are non-sensitive only;
# anything matching *.secret.tfvars or *.auto.tfvars is excluded.
*.secret.tfvars
*.secret.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
