{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource receiving OTel Collector metrics + ElastiCache CloudWatch exporter (optional)",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "inflect-compliance — Redis. App-side: BullMQ queue depth (Redis-backed). AWS-side: ElastiCache CloudWatch metrics (operator wires the cloudwatch_exporter or YACE).",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Queue depth — waiting",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(job_queue_depth{queue_state=\"waiting\"})",
          "legendFormat": "waiting",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Queue depth — active",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(job_queue_depth{queue_state=\"active\"})",
          "legendFormat": "active",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "ElastiCache CPU (avg)",
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Requires AWS CloudWatch exporter (cloudwatch_exporter or YACE) configured for ElastiCache.",
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(aws_elasticache_engine_cpu_utilization_average)",
          "legendFormat": "cpu %",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "ElastiCache memory used",
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(aws_elasticache_database_memory_usage_percentage_average)",
          "legendFormat": "mem %",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "BullMQ queue depth by state",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (queue_state) (job_queue_depth)",
          "legendFormat": "{{queue_state}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ElastiCache ops/sec",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Requires AWS CloudWatch exporter for ElastiCache.",
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(aws_elasticache_get_type_cmds_sum[5m]))",
          "legendFormat": "GET",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(aws_elasticache_set_type_cmds_sum[5m]))",
          "legendFormat": "SET",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ElastiCache cache hit rate",
      "id": 7,
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "hits / (hits + misses). Requires AWS CloudWatch exporter.",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg(rate(aws_elasticache_cache_hits_sum[5m])) / clamp_min(avg(rate(aws_elasticache_cache_hits_sum[5m])) + avg(rate(aws_elasticache_cache_misses_sum[5m])), 1)",
          "legendFormat": "hit rate",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "ElastiCache evicted keys (rate)",
      "id": 8,
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "BullMQ requires maxmemory-policy=noeviction. Non-zero values here mean the chart's Redis parameter group has drifted.",
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(aws_elasticache_evictions_sum[5m]))",
          "legendFormat": "evictions/s",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["inflect", "redis", "elasticache"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Inflect — Redis / ElastiCache",
  "uid": "inflect-redis",
  "version": 1,
  "weekStart": ""
}
